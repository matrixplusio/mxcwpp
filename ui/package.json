    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.5.1",
    "happy-dom": "^20.9.0",
    "less": "^4.4.2",
