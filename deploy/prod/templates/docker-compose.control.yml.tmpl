name: mxcwpp-control

services:
  manager:
    image: {{ .ManagerImage }}
    restart: always
    network_mode: host
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxcwpp/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxcwpp/certs:ro
      - {{ .DataRoot }}/logs/manager:/var/log/mxcwpp
      - {{ .DataRoot }}/plugins:/opt/mxcwpp/plugins
      - {{ .DataRoot }}/uploads:/opt/mxcwpp/uploads
      - {{ .DataRoot }}/data:/opt/mxcwpp/data
      - {{ .DataRoot }}/clamav:/var/lib/clamav
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  agentcenter:
    image: {{ .AgentCenterImage }}
    restart: always
    network_mode: host
    volumes:
      - {{ .InstallDir }}/current/config/server-ac.yaml:/etc/mxcwpp/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxcwpp/certs:ro
      - {{ .DataRoot }}/logs/agentcenter:/var/log/mxcwpp
      - {{ .DataRoot }}/plugins:/opt/mxcwpp/plugins
      - {{ .DataRoot }}/data:/opt/mxcwpp/data:ro
      - {{ .DataRoot }}/uploads:/opt/mxcwpp/uploads:ro
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 6751"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s

{{- if gt .Assignment.ConsumerReplicas 0 }}
  consumer:
    image: {{ .ConsumerImage }}
    restart: always
    network_mode: host
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxcwpp/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxcwpp/certs:ro
      - {{ .DataRoot }}/logs/consumer:/var/log/mxcwpp
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD-SHELL", "kill -0 1 || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
{{- end }}

{{- if gt .Assignment.EngineReplicas 0 }}
  # ===== Engine v2.0 检测分析引擎 =====
  # 订阅 mxcwpp.agent.* (ConsumerGroup B "mxcwpp-engine"), 与 consumer 独立 offset.
  # 16 stages: CEL / sequence / anomaly / ML / audit / intrusion / kube / RASP / storyline 等.
  engine:
    image: {{ .EngineImage }}
    restart: always
    network_mode: host
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxcwpp/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxcwpp/certs:ro
      - {{ .DataRoot }}/logs/engine:/var/log/mxcwpp
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1:8082/health"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 60s
{{- end }}

{{- if gt .Assignment.LLMProxyReplicas 0 }}
  # ===== LLMProxy v2.0 多 LLM 厂商适配网关 =====
  # 7 providers: OpenAI / Anthropic / Gemini / DashScope / DeepSeek / Ollama / vLLM
  # 4 scene routing: alert_explain / storyline_summary / nl2query / rule_draft
  llmproxy:
    image: {{ .LLMProxyImage }}
    restart: always
    network_mode: host
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxcwpp/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxcwpp/certs:ro
      - {{ .DataRoot }}/logs/llmproxy:/var/log/mxcwpp
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1:8085/health"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
{{- end }}

{{- if gt .Assignment.VulnSyncReplicas 0 }}
  # ===== VulnSync v2.0 漏洞情报融合 =====
  # 11+ sources: NVD / OSV / RHSA / USN / CISA KEV / EPSS / CNNVD / 信创 (Kylin/UOS/openEuler/anolis)
  # PURL+NEVRA 双索引 + Leader Election (redsync 避免多副本重复抓取).
  vulnsync:
    image: {{ .VulnSyncImage }}
    restart: always
    network_mode: host
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxcwpp/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxcwpp/certs:ro
      - {{ .DataRoot }}/logs/vulnsync:/var/log/mxcwpp
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1:8083/health"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 60s
{{- end }}

  ui:
    image: {{ .UIImage }}
    restart: always
    network_mode: host
    depends_on:
      manager:
        condition: service_healthy
    volumes:
      - {{ .InstallDir }}/current/config/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - {{ .DataRoot }}/logs/nginx:/var/log/nginx
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  # ===== PDF 服务端渲染（可选）=====
  # Gotenberg 8 sidecar，提供 Chromium → PDF 转换。
  # 替代前端 jsPDF（万行级数据集会让浏览器崩）。
  # 配套 server.yaml 的 pdf.gotenberg_url 与 pdf.internal_url 字段。
  gotenberg:
    image: gotenberg/gotenberg:8
    restart: always
    network_mode: host
    command:
      - "gotenberg"
      - "--api-port=3000"
      - "--chromium-disable-web-security"
      - "--chromium-allow-list=.*"
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://127.0.0.1:3000/health"]
      interval: 30s
      timeout: 5s
      retries: 3
