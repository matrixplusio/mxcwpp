# Matrix Cloud Security Platform - 环境变量配置
# 复制为 .env 后按需修改；dev 默认值可直接使用
# cp .env.example .env

# === General ===
VERSION=dev
TZ=Asia/Shanghai

# === MySQL ===
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=mxsec
MYSQL_USER=mxsec_user
MYSQL_HOST=mysql
MYSQL_PORT=3306
DB_MAX_IDLE_CONNS=20
DB_MAX_OPEN_CONNS=200
DB_CONN_MAX_LIFETIME=1h

# === Redis ===
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100
REDIS_SENTINEL=false
REDIS_MASTER_NAME=mymaster
REDIS_SENTINEL_ADDR_1=redis-sentinel-1:26379
REDIS_SENTINEL_ADDR_2=redis-sentinel-2:26379
REDIS_SENTINEL_ADDR_3=redis-sentinel-3:26379

# === Kafka ===
KAFKA_ENABLED=true
KAFKA_BROKER_1=kafka-1:9092
KAFKA_BROKER_2=kafka-2:9092
KAFKA_BROKER_3=kafka-3:9092
KAFKA_TOPIC_PREFIX=

# === ClickHouse ===
CLICKHOUSE_ENABLED=true
CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DATABASE=mxsec
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# === Prometheus ===
PROMETHEUS_ENABLED=true
PROMETHEUS_QUERY_URL=http://prometheus:9090
PROMETHEUS_TIMEOUT=10s

# === Networking ===
SERVER_IP=127.0.0.1
GRPC_PORT=6751
SERVER_HTTP_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443
MANAGER_PORT=8080
MANAGER_ADDR=http://manager:8080
INSTANCE_ID=

# === 控制面副本数（默认 1=单副本用于单机/功能验证；生产建议 2+ 实现 HA） ===
# deploy.sh 的 start/upgrade 会按此读取并显式生成 --scale 参数，保持升级前后副本数一致
MANAGER_REPLICAS=1
AGENTCENTER_REPLICAS=1
CONSUMER_REPLICAS=1

# === Data ===
DATA_DIR=./data

# === Logging ===
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_MAX_AGE=7
LOG_RETENTION_DAYS=7

# === Agent ===
HEARTBEAT_INTERVAL=60

# === Plugins ===
PLUGINS_DIR=/opt/mxsec-platform/plugins
PLUGINS_BASE_URL=

# === JWT ===
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# === Internal Communication ===
INTERNAL_SECRET=
CORS_ORIGINS=[]

# === Metrics ===
METRICS_BASIC_AUTH_USER=
METRICS_BASIC_AUTH_PASSWORD=
