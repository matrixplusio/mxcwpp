# mxsec v2.0 docker-compose.v2.yml 环境变量 (P3-17)
#
# 用法:
#   cp deploy/env.v2.example deploy/.env
#   vim deploy/.env
#   docker compose -f deploy/docker-compose.v2.yml --env-file deploy/.env up -d
#
# 密钥生成命令在每项右侧.

# ===== 基础设施密码 =====
MYSQL_ROOT_PASSWORD=changeMe123!@#                   # openssl rand -hex 16
MYSQL_PASSWORD=mxsecAppPass789!@#                    # openssl rand -hex 16
REDIS_PASSWORD=mxsecRedis456!@#                      # openssl rand -hex 16
CH_PASSWORD=mxsecCH789!@#                            # openssl rand -hex 16
GRAFANA_PASSWORD=grafanaAdmin123                     # openssl rand -hex 12

# ===== mxsec 核心密钥 =====
JWT_SECRET=ChangeMe-MustBeAtLeast32CharsLong-Random  # openssl rand -hex 32
INTERNAL_SECRET=mxsecInternalSecret789               # openssl rand -hex 16
KMS_KEK_V1=                                          # go run ./cmd/tools/kms-gen-kek

# ===== 第三方 API (可选) =====
NVD_API_KEY=                                         # https://nvd.nist.gov/developers/request-an-api-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===== 镜像配置 =====
REGISTRY=ghcr.io/imkerbos
VERSION=2.0.0
