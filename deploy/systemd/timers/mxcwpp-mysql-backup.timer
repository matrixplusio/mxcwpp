[Unit]
Description=mxcwpp MySQL backup timer (daily full + hourly incremental)
Documentation=https://github.com/matrixplusio/mxcwpp

[Timer]
# 02:00 daily full backup
OnCalendar=*-*-* 02:00:00
# 每小时增量 (实际由脚本 service 决策)
RandomizedDelaySec=600
Persistent=true
Unit=mxcwpp-mysql-backup.service

[Install]
WantedBy=timers.target
