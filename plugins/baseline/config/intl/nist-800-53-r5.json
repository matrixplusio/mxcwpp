{
  "id": "INTL_NIST_800_53_R5",
  "name": "NIST SP 800-53 Rev 5 Linux 主机基线 (US Federal Information Systems)",
  "version": "1.0.0",
  "description": "NIST 800-53 R5 控制族适用于 Linux 主机的部分: AC/AU/IA/SC/SI",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "NIST_AC_2", "category": "Access Control", "title": "AC-2 账户管理 — 默认账户禁用", "description": "AC-2(c) Identify and disable account types not required", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["awk -F: '($2 == \"\")' /etc/shadow | wc -l", "^0$"]}]}, "fix": {"suggestion": "passwd -l <empty-pw-user>"}},
    {"rule_id": "NIST_AC_7", "category": "Access Control", "title": "AC-7 失败登录尝试", "description": "AC-7(a) 失败 6 次锁定 30min", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/pam.d/system-auth", "pam_faillock.*deny=([1-6])", "match"]}]}, "fix": {"suggestion": "pam_faillock deny=6 unlock_time=1800"}},
    {"rule_id": "NIST_AC_11", "category": "Access Control", "title": "AC-11 会话锁定 15min", "description": "AC-11(a) Initiate session lock after 15min idle", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/profile", "^\\s*(TMOUT|export TMOUT)=([1-9][0-9]{0,2})", "match"]}]}, "fix": {"suggestion": "/etc/profile: export TMOUT=900"}},
    {"rule_id": "NIST_AC_12", "category": "Access Control", "title": "AC-12 自动会话终止", "description": "AC-12 idle 终止 SSH 会话", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/ssh/sshd_config", "^ClientAliveInterval\\s+([1-9][0-9]{0,2})", "match"]}]}, "fix": {"suggestion": "ClientAliveInterval 300 + ClientAliveCountMax 0"}},
    {"rule_id": "NIST_AU_2", "category": "Audit and Accountability", "title": "AU-2 审计事件类型", "description": "AU-2(d) Identify event types to audit (login/logout/account/system)", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "service_status", "param": ["auditd", "active"]}]}, "fix": {"suggestion": "systemctl enable --now auditd"}},
    {"rule_id": "NIST_AU_9", "category": "Audit and Accountability", "title": "AU-9 审计信息保护", "description": "AU-9 审计日志文件权限 ≤600", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/var/log/audit/audit.log", "600"]}]}, "fix": {"suggestion": "chmod 600 /var/log/audit/audit.log + chown root:root"}},
    {"rule_id": "NIST_AU_12", "category": "Audit and Accountability", "title": "AU-12 审计记录生成", "description": "AU-12(a) 审计规则非空", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["auditctl -l 2>/dev/null | wc -l", "[1-9][0-9]*"]}]}, "fix": {"suggestion": "/etc/audit/rules.d/audit.rules 添加 watch + syscall 规则"}},
    {"rule_id": "NIST_IA_5", "category": "Identification and Authentication", "title": "IA-5 认证管理 — 密码复杂度", "description": "IA-5(1) 密码复杂度: minlen 12 + 3 character class", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/security/pwquality.conf", "minlen\\s*=\\s*(1[2-9]|[2-9][0-9])", "match"]}]}, "fix": {"suggestion": "minlen=12 + minclass=3"}},
    {"rule_id": "NIST_IA_5_2", "category": "Identification", "title": "IA-5(2) PKI / 密钥认证 (SSH)", "description": "禁密码登录", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/ssh/sshd_config", "^PasswordAuthentication\\s+no", "match"]}]}, "fix": {"suggestion": "PasswordAuthentication no"}},
    {"rule_id": "NIST_SC_7", "category": "System Communications", "title": "SC-7 边界保护 — firewall", "description": "SC-7(a) Monitor and control communications", "severity": "high", "check": {"condition": "any", "rules": [{"type": "service_status", "param": ["firewalld", "active"]}, {"type": "service_status", "param": ["nftables", "active"]}, {"type": "service_status", "param": ["iptables", "active"]}, {"type": "service_status", "param": ["ufw", "active"]}]}, "fix": {"suggestion": "systemctl enable --now firewalld"}},
    {"rule_id": "NIST_SC_8", "category": "System Communications", "title": "SC-8 传输保护", "description": "SC-8 TLS 加密 — 禁明文协议", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "service_status", "param": ["telnet.socket", "active"]}, {"type": "service_status", "param": ["rsh.socket", "active"]}]}, "fix": {"suggestion": "禁用 telnet/rsh, 用 SSH 替代"}},
    {"rule_id": "NIST_SI_2", "category": "System Integrity", "title": "SI-2 漏洞修复 — 自动补丁", "description": "SI-2(c) Install patches", "severity": "high", "check": {"condition": "any", "rules": [{"type": "service_status", "param": ["dnf-automatic.timer", "active"]}, {"type": "service_status", "param": ["unattended-upgrades", "active"]}]}, "fix": {"suggestion": "RHEL: dnf install dnf-automatic + systemctl enable --now dnf-automatic.timer"}},
    {"rule_id": "NIST_SI_7", "category": "System Integrity", "title": "SI-7 软件/固件完整性", "description": "SI-7 文件完整性监控 (FIM)", "severity": "high", "check": {"condition": "any", "rules": [{"type": "command_exec", "param": ["which aide tripwire 2>/dev/null | head -1", ".+"]}]}, "fix": {"suggestion": "yum install aide && aide --init"}}
  ]
}
