{
  "id": "INTL_HIPAA",
  "name": "HIPAA Security Rule 主机基线 (Health Insurance Portability and Accountability Act)",
  "version": "1.0.0",
  "description": "HIPAA Security Rule §164.308-§164.312 Administrative/Physical/Technical Safeguards 适用于 Linux 主机的部分",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "HIPAA_164_308_a_4_i", "category": "Access Management", "title": "唯一用户标识 (Unique User ID)", "description": "§164.308(a)(4)(i) 每用户独立账户, 禁用通用账户", "severity": "high", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["grep -E '^(guest|nobody|public):' /etc/passwd | grep -v ':\\*:\\|:!:\\|nologin' | wc -l", "^0$"]}]}, "fix": {"suggestion": "userdel guest / public 或 usermod -L 锁定"}},
    {"rule_id": "HIPAA_164_308_a_5_ii_D", "category": "Workforce Security", "title": "密码强度", "description": "§164.308(a)(5)(ii)(D) 密码管理", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/security/pwquality.conf", "minlen\\s*=\\s*(1[0-9]|[2-9][0-9])", "match"]}]}, "fix": {"suggestion": "minlen=10+ in /etc/security/pwquality.conf"}},
    {"rule_id": "HIPAA_164_308_a_6_ii", "category": "Security Incident", "title": "审计日志启用", "description": "§164.308(a)(6)(ii) 安全事件追踪", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "service_status", "param": ["auditd", "active"]}]}, "fix": {"suggestion": "systemctl enable --now auditd"}},
    {"rule_id": "HIPAA_164_310_a_2_iii", "category": "Physical Access", "title": "工作站锁屏 (Workstation Use)", "description": "§164.310(a)(2)(iii) GNOME idle lock / vlock", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "command_exec", "param": ["which gnome-screensaver vlock 2>/dev/null | head -1", ".+"]}]}, "fix": {"suggestion": "yum install vlock 或配置 GNOME screen lock 10min"}},
    {"rule_id": "HIPAA_164_312_a_1", "category": "Access Control", "title": "强制访问控制 SELinux/AppArmor", "description": "§164.312(a)(1) PHI 数据访问最小权限", "severity": "high", "check": {"condition": "any", "rules": [{"type": "command_exec", "param": ["getenforce 2>/dev/null", "Enforcing"]}, {"type": "command_exec", "param": ["aa-status 2>/dev/null | grep -c 'profiles are in enforce mode'", "[1-9]"]}]}, "fix": {"suggestion": "setenforce 1 + /etc/selinux/config SELINUX=enforcing"}},
    {"rule_id": "HIPAA_164_312_a_2_iii", "category": "Access Control", "title": "自动注销 (Automatic Logoff)", "description": "§164.312(a)(2)(iii) idle 15min 自动注销", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/profile", "^\\s*(TMOUT|export TMOUT)=([1-9]|[1-8][0-9]?[0-9])", "match"]}]}, "fix": {"suggestion": "/etc/profile: export TMOUT=900 (15 min)"}},
    {"rule_id": "HIPAA_164_312_b", "category": "Audit Controls", "title": "审计实施 (Audit Controls)", "description": "§164.312(b) 实施 hardware/software/procedural 审计机制", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["auditctl -l 2>/dev/null | wc -l", "[1-9][0-9]*"]}]}, "fix": {"suggestion": "audit.rules 至少包含 -w /etc/passwd -p wa + -a always,exit -F arch=b64 -S execve"}},
    {"rule_id": "HIPAA_164_312_c_1", "category": "Integrity", "title": "文件完整性监控 (FIM)", "description": "§164.312(c)(1) PHI 完整性保护 — aide/tripwire", "severity": "high", "check": {"condition": "any", "rules": [{"type": "command_exec", "param": ["which aide tripwire 2>/dev/null | head -1", ".+"]}]}, "fix": {"suggestion": "yum install aide && aide --init"}},
    {"rule_id": "HIPAA_164_312_d", "category": "Person/Entity Authentication", "title": "MFA / 2FA (SSH 密钥认证)", "description": "§164.312(d) 身份认证 — 至少密钥认证, 推荐 MFA", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/ssh/sshd_config", "^PasswordAuthentication\\s+no", "match"]}]}, "fix": {"suggestion": "PasswordAuthentication no 在 sshd_config"}},
    {"rule_id": "HIPAA_164_312_e_1", "category": "Transmission Security", "title": "传输加密 (TLS)", "description": "§164.312(e)(1) PHI 跨网络传输加密", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "service_status", "param": ["telnet.socket", "active"]}, {"type": "service_status", "param": ["ftp", "active"]}, {"type": "service_status", "param": ["rsh.socket", "active"]}]}, "fix": {"suggestion": "禁用 telnet/ftp/rsh, 替为 SSH/SFTP/HTTPS"}}
  ]
}
