{
  "id": "INTL_PCI_DSS_4_0",
  "name": "PCI-DSS 4.0 Linux 主机基线 (Payment Card Industry Data Security Standard)",
  "version": "1.0.0",
  "description": "PCI-DSS 4.0 12 大类要求中适用于 Linux 主机的合规检查, 覆盖 Req 2/3/6/7/8/10",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "PCI_DSS_2_2_1", "category": "Req 2: Secure Configurations", "title": "禁用默认账户口令", "description": "PCI-DSS 2.2.1 vendor default 账户必须改密或禁用", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/shadow", "^root:\\*", "match"]}]}, "fix": {"suggestion": "passwd root 改强密码"}},
    {"rule_id": "PCI_DSS_2_2_2", "category": "Req 2", "title": "禁用未用的网络服务", "description": "PCI-DSS 2.2.2 仅运行必需服务", "severity": "high", "check": {"condition": "none", "rules": [{"type": "service_status", "param": ["telnet.socket", "active"]}, {"type": "service_status", "param": ["rsh.socket", "active"]}, {"type": "service_status", "param": ["rlogin.socket", "active"]}]}, "fix": {"suggestion": "systemctl disable telnet rsh rlogin"}},
    {"rule_id": "PCI_DSS_2_2_5", "category": "Req 2", "title": "SNMP community string 非 default", "description": "PCI-DSS 2.2.5 SNMP public/private 默认 community 禁用", "severity": "high", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/etc/snmp/snmpd.conf", "^(rwcommunity|rocommunity)\\s+(public|private)", "match"]}]}, "fix": {"suggestion": "改用 SNMPv3 + auth/priv"}},
    {"rule_id": "PCI_DSS_3_5_1", "category": "Req 3: Protect Cardholder Data", "title": "/etc/shadow 权限 ≤640", "description": "PCI-DSS 3.5 加密密钥/口令存储保护", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/shadow", "640"]}]}, "fix": {"suggestion": "chmod 640 /etc/shadow"}},
    {"rule_id": "PCI_DSS_6_2_1", "category": "Req 6: Secure Systems", "title": "自动安全更新启用", "description": "PCI-DSS 6.2 关键漏洞 1 月内修复", "severity": "high", "check": {"condition": "any", "rules": [{"type": "service_status", "param": ["dnf-automatic.timer", "active"]}, {"type": "service_status", "param": ["unattended-upgrades", "active"]}, {"type": "service_status", "param": ["yum-cron", "active"]}]}, "fix": {"suggestion": "RHEL: systemctl enable --now dnf-automatic.timer; Debian: apt install unattended-upgrades"}},
    {"rule_id": "PCI_DSS_7_2_1", "category": "Req 7: Restrict Access", "title": "sudo 不允许 NOPASSWD", "description": "PCI-DSS 7.2.1 最小权限, sudo 必须密码", "severity": "high", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["grep -r 'NOPASSWD' /etc/sudoers /etc/sudoers.d/ 2>/dev/null | grep -v '^#'", ".+"]}]}, "fix": {"suggestion": "/etc/sudoers 删除 NOPASSWD 或迁到指定低风险命令"}},
    {"rule_id": "PCI_DSS_8_2_3", "category": "Req 8: Identify Users", "title": "密码长度 ≥12", "description": "PCI-DSS 8.3.6 密码 12 字符起", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/security/pwquality.conf", "^minlen\\s*=\\s*(1[2-9]|[2-9][0-9])", "match"]}]}, "fix": {"suggestion": "minlen=12 in /etc/security/pwquality.conf"}},
    {"rule_id": "PCI_DSS_8_2_4", "category": "Req 8", "title": "密码 90 天过期", "description": "PCI-DSS 8.3.9 密码过期 ≤90 天", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/login.defs", "PASS_MAX_DAYS", "^([1-8]?[0-9]|90)$"]}]}, "fix": {"suggestion": "PASS_MAX_DAYS 90 in /etc/login.defs"}},
    {"rule_id": "PCI_DSS_8_3_5", "category": "Req 8", "title": "登录失败 6 次锁定", "description": "PCI-DSS 8.3.5 失败 6 次锁定 30min", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/pam.d/system-auth", "pam_faillock.*deny=([1-6])", "match"]}]}, "fix": {"suggestion": "auth required pam_faillock.so preauth silent deny=6 unlock_time=1800"}},
    {"rule_id": "PCI_DSS_10_2_1", "category": "Req 10: Track and Monitor", "title": "auditd 启用", "description": "PCI-DSS 10.2.1 审计所有访问 cardholder data", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "service_status", "param": ["auditd", "active"]}]}, "fix": {"suggestion": "systemctl enable --now auditd"}},
    {"rule_id": "PCI_DSS_10_3_1", "category": "Req 10", "title": "审计日志远程归集", "description": "PCI-DSS 10.3 + 10.5 异地存储", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/rsyslog.conf", "^\\*\\.\\*\\s+@", "match"]}, {"type": "file_line_match", "param": ["/etc/rsyslog.d/.*\\.conf", "^\\*\\.\\*\\s+@", "match"]}]}, "fix": {"suggestion": "*.* @logsvr.example.com:514 in /etc/rsyslog.conf"}},
    {"rule_id": "PCI_DSS_10_4_1", "category": "Req 10", "title": "NTP 时间同步", "description": "PCI-DSS 10.6 系统时钟同步审计前提", "severity": "high", "check": {"condition": "any", "rules": [{"type": "service_status", "param": ["chronyd", "active"]}, {"type": "service_status", "param": ["ntpd", "active"]}, {"type": "service_status", "param": ["systemd-timesyncd", "active"]}]}, "fix": {"suggestion": "systemctl enable --now chronyd"}}
  ]
}
