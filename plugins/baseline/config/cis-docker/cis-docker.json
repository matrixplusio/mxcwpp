{
  "id": "CIS_DOCKER_BENCHMARK",
  "name": "CIS Docker Benchmark - Host + Daemon + Container + Image (4 维)",
  "version": "1.0.0",
  "description": "CIS Docker Community Edition Benchmark v1.6.0. 4 维度: 主机配置 / Docker 守护进程 / 容器运行时 / 镜像构建.",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "CIS_DOCKER_1_1_1", "category": "Host: 分区", "title": "/var/lib/docker 独立分区", "description": "Docker 数据目录满会撑爆 root, 推荐独立分区", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["mount | grep -c '/var/lib/docker'", "^[1-9]"]}]}, "fix": {"suggestion": "规划阶段独立挂载 /var/lib/docker (LVM 或 XFS)"}},
    {"rule_id": "CIS_DOCKER_1_2_1", "category": "Host: 内核", "title": "内核版本 ≥3.10", "description": "Docker 要求 3.10+, 推荐 4.x+", "severity": "low", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["uname -r | awk -F. '{ print ($1*100 + $2) }' | awk '$1 >= 310'", "^[3-9][0-9][0-9]$|^[1-9][0-9]{3,}$"]}]}, "fix": {"suggestion": "升级内核 yum update kernel / apt install linux-generic"}},
    {"rule_id": "CIS_DOCKER_1_2_2", "category": "Host: 内核", "title": "审计 dockerd 配置", "description": "/etc/docker/daemon.json 必须 audit", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/audit/rules.d/audit.rules", "/etc/docker", "match"]}]}, "fix": {"suggestion": "-w /etc/docker -p wa -k docker"}},
    {"rule_id": "CIS_DOCKER_1_2_3", "category": "Host: 审计", "title": "审计 /usr/bin/dockerd", "description": "二进制审计", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["auditctl -l 2>/dev/null | grep -c /usr/bin/dockerd", "^[1-9]"]}]}, "fix": {"suggestion": "-w /usr/bin/dockerd -p wa -k docker"}},
    {"rule_id": "CIS_DOCKER_2_1", "category": "Daemon: 网络", "title": "禁用 iptables=false", "description": "Docker 必须托管 iptables 自动隔离容器", "severity": "high", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"iptables\":\\s*false", "match"]}]}, "fix": {"suggestion": "daemon.json 删除 iptables=false"}},
    {"rule_id": "CIS_DOCKER_2_2", "category": "Daemon: 日志", "title": "默认日志驱动 json-file / journald", "description": "防 logspout 漏失", "severity": "low", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"log-driver\":\\s*\"(json-file|journald|fluentd|syslog)\"", "match"]}]}, "fix": {"suggestion": "daemon.json log-driver: json-file (+ max-size/max-file)"}},
    {"rule_id": "CIS_DOCKER_2_3", "category": "Daemon: 日志", "title": "日志文件大小限制", "description": "防容器日志撑爆磁盘", "severity": "low", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"max-size\":", "match"]}]}, "fix": {"suggestion": "daemon.json log-opts: max-size=10m max-file=3"}},
    {"rule_id": "CIS_DOCKER_2_4", "category": "Daemon: 网络", "title": "禁用 inter-container 通信", "description": "icc=false 防容器间默认互通", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"icc\":\\s*false", "match"]}]}, "fix": {"suggestion": "daemon.json icc=false (依赖 docker network 显式 link)"}},
    {"rule_id": "CIS_DOCKER_2_5", "category": "Daemon: 安全", "title": "启用 userns-remap", "description": "容器 root 映射宿主非 root", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"userns-remap\":\\s*\"[^\"]+\"", "match"]}]}, "fix": {"suggestion": "daemon.json userns-remap=default"}},
    {"rule_id": "CIS_DOCKER_2_6", "category": "Daemon: 网络", "title": "禁止 daemon 监听 TCP", "description": "默认 unix socket, TCP 暴露 RCE 风险", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"hosts\":.*tcp://", "match"]}, {"type": "command_exec", "param": ["ss -ltn 2>/dev/null | grep -c ':237[56]'", "^0$"]}]}, "fix": {"suggestion": "daemon.json 删除 tcp://0.0.0.0; 仅 unix:///var/run/docker.sock"}},
    {"rule_id": "CIS_DOCKER_2_7", "category": "Daemon: 安全", "title": "禁用 v1 镜像", "description": "v1 缺签名, 易污染", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"disable-legacy-registry\":\\s*true", "match"]}]}, "fix": {"suggestion": "daemon.json disable-legacy-registry=true"}},
    {"rule_id": "CIS_DOCKER_2_8", "category": "Daemon: 安全", "title": "启用 Live Restore", "description": "dockerd 重启不停容器", "severity": "low", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/docker/daemon.json", "\"live-restore\":\\s*true", "match"]}]}, "fix": {"suggestion": "daemon.json live-restore=true"}},
    {"rule_id": "CIS_DOCKER_2_9", "category": "Daemon: 内容信任", "title": "启用 content trust", "description": "DOCKER_CONTENT_TRUST=1 强制镜像签名验证", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["systemctl show docker -p Environment 2>/dev/null | grep -c DOCKER_CONTENT_TRUST=1", "^[1-9]"]}]}, "fix": {"suggestion": "systemd Environment=DOCKER_CONTENT_TRUST=1"}},
    {"rule_id": "CIS_DOCKER_3_1", "category": "文件权限", "title": "docker.sock 权限 ≤660", "description": "/var/run/docker.sock 仅 root + docker 组", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["stat -c '%a' /var/run/docker.sock 2>/dev/null", "^660$|^600$"]}]}, "fix": {"suggestion": "chmod 660 /var/run/docker.sock && chown root:docker"}},
    {"rule_id": "CIS_DOCKER_3_2", "category": "文件权限", "title": "/etc/docker/daemon.json 权限 ≤644", "description": "配置文件保护", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/docker/daemon.json", "644"]}]}, "fix": {"suggestion": "chmod 644 /etc/docker/daemon.json && chown root:root"}},
    {"rule_id": "CIS_DOCKER_3_3", "category": "文件权限", "title": "docker.service 权限 ≤644", "description": "systemd unit 保护", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_permission", "param": ["/usr/lib/systemd/system/docker.service", "644"]}, {"type": "file_permission", "param": ["/lib/systemd/system/docker.service", "644"]}]}, "fix": {"suggestion": "chmod 644 docker.service"}},
    {"rule_id": "CIS_DOCKER_4_1", "category": "Container: 运行时", "title": "禁用 privileged 容器", "description": "--privileged 等于 root + cap_sys_admin", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.HostConfig.Privileged}}' {} 2>/dev/null | grep -c true", "^0$"]}]}, "fix": {"suggestion": "去掉 --privileged, 改用 --cap-add 精确授权"}},
    {"rule_id": "CIS_DOCKER_4_2", "category": "Container: 运行时", "title": "禁用 host network", "description": "--net=host 等于无网络隔离", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.HostConfig.NetworkMode}}' {} 2>/dev/null | grep -c '^host$'", "^0$"]}]}, "fix": {"suggestion": "不使用 --net=host"}},
    {"rule_id": "CIS_DOCKER_4_3", "category": "Container: 运行时", "title": "禁用 host PID", "description": "--pid=host 容器看到所有进程", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.HostConfig.PidMode}}' {} 2>/dev/null | grep -c '^host$'", "^0$"]}]}, "fix": {"suggestion": "不使用 --pid=host"}},
    {"rule_id": "CIS_DOCKER_4_4", "category": "Container: 运行时", "title": "禁挂载 /var/run/docker.sock", "description": "Docker socket 挂载 = 容器逃逸", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{range .Mounts}}{{.Source}}\\n{{end}}' {} 2>/dev/null | grep -c '/var/run/docker.sock'", "^0$"]}]}, "fix": {"suggestion": "改用 docker API mTLS 或专用 sidecar"}},
    {"rule_id": "CIS_DOCKER_4_5", "category": "Container: 运行时", "title": "AppArmor / SELinux 启用", "description": "强制访问控制约束容器", "severity": "high", "check": {"condition": "any", "rules": [{"type": "service_status", "param": ["apparmor", "active"]}, {"type": "command_exec", "param": ["getenforce 2>/dev/null", "^Enforcing$"]}]}, "fix": {"suggestion": "systemctl enable --now apparmor 或 setenforce 1"}},
    {"rule_id": "CIS_DOCKER_4_6", "category": "Container: 运行时", "title": "禁用 --user-ns=host", "description": "user namespace 隔离 root", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.HostConfig.UsernsMode}}' {} 2>/dev/null | grep -c '^host$'", "^0$"]}]}, "fix": {"suggestion": "不使用 --userns=host"}},
    {"rule_id": "CIS_DOCKER_4_7", "category": "Container: 资源限制", "title": "容器内存限制存在", "description": "防容器 OOM 拖垮宿主", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.HostConfig.Memory}}' {} 2>/dev/null | grep -c '^0$'", "^0$"]}]}, "fix": {"suggestion": "docker run --memory=512m"}},
    {"rule_id": "CIS_DOCKER_4_8", "category": "Container: 资源限制", "title": "容器 CPU 限制存在", "description": "公平调度", "severity": "low", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.HostConfig.CpuShares}}' {} 2>/dev/null | grep -c '^0$'", "^0$"]}]}, "fix": {"suggestion": "docker run --cpu-shares=1024"}},
    {"rule_id": "CIS_DOCKER_4_9", "category": "Container: 健康检查", "title": "容器 HEALTHCHECK 配置", "description": "便于 orchestrator 自动重启", "severity": "low", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.Config.Healthcheck}}' {} 2>/dev/null | grep -c '<nil>'", "^0$"]}]}, "fix": {"suggestion": "Dockerfile 加 HEALTHCHECK"}},
    {"rule_id": "CIS_DOCKER_5_1", "category": "Image: 信任", "title": "Image 包含 USER 指令", "description": "防 root 进程", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.ID}}' 2>/dev/null | xargs -I{} docker inspect --format='{{.Config.User}}' {} 2>/dev/null | grep -c '^$'", "^0$"]}]}, "fix": {"suggestion": "Dockerfile 加 USER nonroot 或镜像基底用 distroless/nonroot"}},
    {"rule_id": "CIS_DOCKER_5_2", "category": "Image: 内容", "title": "镜像无 setuid/setgid 文件", "description": "防容器内提权", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["find /var/lib/docker -perm /6000 -type f 2>/dev/null | wc -l", "^0$|^[1-9]$"]}]}, "fix": {"suggestion": "Dockerfile 多阶段 + chmod u-s g-s"}},
    {"rule_id": "CIS_DOCKER_5_3", "category": "Image: tag", "title": "禁用 :latest tag", "description": "不可复现", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.Image}}' 2>/dev/null | grep -c ':latest'", "^0$"]}]}, "fix": {"suggestion": "镜像 tag 用 sha256:digest 或语义版本"}},
    {"rule_id": "CIS_DOCKER_5_4", "category": "Image: 内容", "title": "镜像源可信", "description": "仅允许私有 registry 或官方 registry", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["docker ps --format '{{.Image}}' 2>/dev/null | grep -vE '^(registry\\.example\\.com|gcr\\.io|docker\\.io/library)' | wc -l", "^0$"]}]}, "fix": {"suggestion": "白名单 registry, 拒绝其他 (docker daemon.json registries 配置)"}}
  ]
}
