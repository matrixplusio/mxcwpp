{
  "id": "K8S_CIS_BENCHMARK_V1_27",
  "name": "CIS Kubernetes Benchmark v1.27 (60 条扩展)",
  "version": "1.0.0",
  "description": "CIS Kubernetes Benchmark v1.8.0 for K8s 1.27/1.28/1.29. 控制平面 + 节点 + 策略 + 日志维度.",
  "os_family": ["k8s"],
  "enabled": true,
  "rules": [
    {"rule_id": "K8S_1_1_1", "category": "Master Node: 文件权限", "title": "API server pod spec 文件权限 ≤644", "description": "1.1.1", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/kubernetes/manifests/kube-apiserver.yaml", "644"]}]}, "fix": {"suggestion": "chmod 644 /etc/kubernetes/manifests/kube-apiserver.yaml"}},
    {"rule_id": "K8S_1_1_2", "category": "Master Node: 文件权限", "title": "API server pod spec 文件 owner = root", "description": "1.1.2", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["stat -c '%U:%G' /etc/kubernetes/manifests/kube-apiserver.yaml 2>/dev/null", "^root:root$"]}]}, "fix": {"suggestion": "chown root:root kube-apiserver.yaml"}},
    {"rule_id": "K8S_1_1_3", "category": "Master Node: 文件权限", "title": "controller-manager pod spec 权限 ≤644", "description": "1.1.3", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/kubernetes/manifests/kube-controller-manager.yaml", "644"]}]}, "fix": {"suggestion": "chmod 644"}},
    {"rule_id": "K8S_1_1_5", "category": "Master Node: 文件权限", "title": "scheduler pod spec 权限 ≤644", "description": "1.1.5", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/kubernetes/manifests/kube-scheduler.yaml", "644"]}]}, "fix": {"suggestion": "chmod 644"}},
    {"rule_id": "K8S_1_1_7", "category": "Master Node: 文件权限", "title": "etcd pod spec 权限 ≤644", "description": "1.1.7", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/kubernetes/manifests/etcd.yaml", "644"]}]}, "fix": {"suggestion": "chmod 644"}},
    {"rule_id": "K8S_1_1_9", "category": "Master Node: 文件权限", "title": "CNI 配置目录权限 ≤644", "description": "1.1.9", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["find /etc/cni/net.d -maxdepth 1 -type f -perm /027 2>/dev/null | wc -l", "^0$"]}]}, "fix": {"suggestion": "chmod 644 /etc/cni/net.d/*"}},
    {"rule_id": "K8S_1_1_11", "category": "Master Node: 文件权限", "title": "etcd 数据目录权限 700", "description": "1.1.11", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_permission", "param": ["/var/lib/etcd", "700"]}]}, "fix": {"suggestion": "chmod 700 /var/lib/etcd"}},
    {"rule_id": "K8S_1_1_19", "category": "Master Node: 证书", "title": "PKI 目录 owner = root", "description": "1.1.19", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["stat -c '%U:%G' /etc/kubernetes/pki 2>/dev/null", "^root:root$"]}]}, "fix": {"suggestion": "chown -R root:root /etc/kubernetes/pki"}},
    {"rule_id": "K8S_1_1_20", "category": "Master Node: 证书", "title": "PKI 证书文件权限 ≤644", "description": "1.1.20", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["find /etc/kubernetes/pki -name '*.crt' -perm /027 2>/dev/null | wc -l", "^0$"]}]}, "fix": {"suggestion": "find /etc/kubernetes/pki -name '*.crt' -exec chmod 644 {} \\;"}},
    {"rule_id": "K8S_1_1_21", "category": "Master Node: 证书", "title": "PKI key 文件权限 ≤600", "description": "1.1.21", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["find /etc/kubernetes/pki -name '*.key' -perm /066 2>/dev/null | wc -l", "^0$"]}]}, "fix": {"suggestion": "find /etc/kubernetes/pki -name '*.key' -exec chmod 600 {} \\;"}},

    {"rule_id": "K8S_1_2_1", "category": "API Server", "title": "--anonymous-auth=false", "description": "1.2.1 禁匿名访问", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --anonymous-auth=false", "^[1-9]"]}]}, "fix": {"suggestion": "API server 启动加 --anonymous-auth=false"}},
    {"rule_id": "K8S_1_2_2", "category": "API Server", "title": "--basic-auth-file 不应配置", "description": "1.2.2 弃用", "severity": "high", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --basic-auth-file", "^[1-9]"]}]}, "fix": {"suggestion": "删除 --basic-auth-file 参数"}},
    {"rule_id": "K8S_1_2_3", "category": "API Server", "title": "--token-auth-file 不应配置", "description": "1.2.3 弃用 (改 RBAC)", "severity": "high", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --token-auth-file", "^[1-9]"]}]}, "fix": {"suggestion": "改用 ServiceAccount + RBAC"}},
    {"rule_id": "K8S_1_2_4", "category": "API Server", "title": "--kubelet-https=true", "description": "1.2.4", "severity": "high", "check": {"condition": "any", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --kubelet-https=false", "^0$"]}]}, "fix": {"suggestion": "默认 true 即可"}},
    {"rule_id": "K8S_1_2_5", "category": "API Server", "title": "--kubelet-certificate-authority 已配置", "description": "1.2.5", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --kubelet-certificate-authority", "^[1-9]"]}]}, "fix": {"suggestion": "API server --kubelet-certificate-authority=/etc/kubernetes/pki/ca.crt"}},
    {"rule_id": "K8S_1_2_6", "category": "API Server", "title": "--authorization-mode 不含 AlwaysAllow", "description": "1.2.6", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --authorization-mode | grep -c AlwaysAllow", "^[1-9]"]}]}, "fix": {"suggestion": "--authorization-mode=Node,RBAC"}},
    {"rule_id": "K8S_1_2_7", "category": "API Server", "title": "--authorization-mode 含 Node", "description": "1.2.7", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --authorization-mode | grep -c Node", "^[1-9]"]}]}, "fix": {"suggestion": "--authorization-mode=Node,RBAC"}},
    {"rule_id": "K8S_1_2_8", "category": "API Server", "title": "--authorization-mode 含 RBAC", "description": "1.2.8", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --authorization-mode | grep -c RBAC", "^[1-9]"]}]}, "fix": {"suggestion": "--authorization-mode=Node,RBAC"}},
    {"rule_id": "K8S_1_2_9", "category": "API Server", "title": "admission EventRateLimit 启用", "description": "1.2.9", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --enable-admission-plugins | grep -c EventRateLimit", "^[1-9]"]}]}, "fix": {"suggestion": "--enable-admission-plugins=EventRateLimit,..."}},
    {"rule_id": "K8S_1_2_10", "category": "API Server", "title": "admission AlwaysAdmit 禁用", "description": "1.2.10", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --enable-admission-plugins | grep -c AlwaysAdmit", "^[1-9]"]}]}, "fix": {"suggestion": "删除 AlwaysAdmit"}},

    {"rule_id": "K8S_1_2_12", "category": "API Server", "title": "admission AlwaysPullImages 启用", "description": "1.2.12 防本地恶意镜像", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --enable-admission-plugins | grep -c AlwaysPullImages", "^[1-9]"]}]}, "fix": {"suggestion": "--enable-admission-plugins=AlwaysPullImages,..."}},
    {"rule_id": "K8S_1_2_14", "category": "API Server", "title": "admission ServiceAccount 启用", "description": "1.2.14", "severity": "high", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --disable-admission-plugins | grep -c ServiceAccount", "^[1-9]"]}]}, "fix": {"suggestion": "不要禁用 ServiceAccount"}},
    {"rule_id": "K8S_1_2_16", "category": "API Server", "title": "admission NodeRestriction 启用", "description": "1.2.16", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -- --enable-admission-plugins | grep -c NodeRestriction", "^[1-9]"]}]}, "fix": {"suggestion": "--enable-admission-plugins=NodeRestriction,..."}},
    {"rule_id": "K8S_1_2_19", "category": "API Server", "title": "--profiling=false", "description": "1.2.19", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --profiling=false", "^[1-9]"]}]}, "fix": {"suggestion": "--profiling=false"}},
    {"rule_id": "K8S_1_2_20", "category": "API Server", "title": "audit-log-path 已配置", "description": "1.2.20", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --audit-log-path", "^[1-9]"]}]}, "fix": {"suggestion": "--audit-log-path=/var/log/apiserver-audit.log"}},
    {"rule_id": "K8S_1_2_22", "category": "API Server", "title": "audit-log-maxage ≥30", "description": "1.2.22", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -oP -- '--audit-log-maxage=[0-9]+' | grep -oP '[0-9]+' | awk '$1>=30'", ".+"]}]}, "fix": {"suggestion": "--audit-log-maxage=30"}},
    {"rule_id": "K8S_1_2_23", "category": "API Server", "title": "audit-log-maxbackup ≥10", "description": "1.2.23", "severity": "low", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -oP -- '--audit-log-maxbackup=[0-9]+' | grep -oP '[0-9]+' | awk '$1>=10'", ".+"]}]}, "fix": {"suggestion": "--audit-log-maxbackup=10"}},
    {"rule_id": "K8S_1_2_27", "category": "API Server", "title": "--tls-cert-file + --tls-private-key-file 已配置", "description": "1.2.27", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- '--tls-cert-file.*--tls-private-key-file\\|--tls-private-key-file.*--tls-cert-file'", "^[1-9]"]}]}, "fix": {"suggestion": "API server TLS 必须启用"}},
    {"rule_id": "K8S_1_2_30", "category": "API Server", "title": "--encryption-provider-config 已配置", "description": "1.2.30 etcd at-rest 加密", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --encryption-provider-config", "^[1-9]"]}]}, "fix": {"suggestion": "--encryption-provider-config=/etc/kubernetes/encryption-config.yaml"}},

    {"rule_id": "K8S_1_3_1", "category": "Controller Manager", "title": "--terminated-pod-gc-threshold 已配置", "description": "1.3.1", "severity": "low", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-controller | grep -c -- --terminated-pod-gc-threshold", "^[1-9]"]}]}, "fix": {"suggestion": "--terminated-pod-gc-threshold=12500"}},
    {"rule_id": "K8S_1_3_2", "category": "Controller Manager", "title": "--profiling=false", "description": "1.3.2", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-controller | grep -c -- --profiling=false", "^[1-9]"]}]}, "fix": {"suggestion": "--profiling=false"}},
    {"rule_id": "K8S_1_3_3", "category": "Controller Manager", "title": "--use-service-account-credentials=true", "description": "1.3.3", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-controller | grep -c -- --use-service-account-credentials=true", "^[1-9]"]}]}, "fix": {"suggestion": "--use-service-account-credentials=true"}},
    {"rule_id": "K8S_1_3_4", "category": "Controller Manager", "title": "--service-account-private-key-file 已配置", "description": "1.3.4", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-controller | grep -c -- --service-account-private-key-file", "^[1-9]"]}]}, "fix": {"suggestion": "--service-account-private-key-file=/etc/kubernetes/pki/sa.key"}},

    {"rule_id": "K8S_1_4_1", "category": "Scheduler", "title": "--profiling=false", "description": "1.4.1", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-scheduler | grep -c -- --profiling=false", "^[1-9]"]}]}, "fix": {"suggestion": "--profiling=false"}},
    {"rule_id": "K8S_1_4_2", "category": "Scheduler", "title": "--bind-address=127.0.0.1", "description": "1.4.2", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-scheduler | grep -c -- --bind-address=127.0.0.1", "^[1-9]"]}]}, "fix": {"suggestion": "--bind-address=127.0.0.1"}},

    {"rule_id": "K8S_2_1", "category": "etcd", "title": "--cert-file + --key-file 已配置", "description": "2.1", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep etcd | grep -c -- '--cert-file.*--key-file\\|--key-file.*--cert-file'", "^[1-9]"]}]}, "fix": {"suggestion": "etcd 必须 TLS"}},
    {"rule_id": "K8S_2_2", "category": "etcd", "title": "--client-cert-auth=true", "description": "2.2", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep etcd | grep -c -- --client-cert-auth=true", "^[1-9]"]}]}, "fix": {"suggestion": "--client-cert-auth=true"}},
    {"rule_id": "K8S_2_3", "category": "etcd", "title": "--auto-tls=false", "description": "2.3", "severity": "high", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["ps -ef | grep etcd | grep -c -- --auto-tls=true", "^[1-9]"]}]}, "fix": {"suggestion": "--auto-tls=false (用真证书)"}},
    {"rule_id": "K8S_2_4", "category": "etcd", "title": "--peer-cert-file + --peer-key-file 已配置", "description": "2.4", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep etcd | grep -c -- '--peer-cert-file.*--peer-key-file\\|--peer-key-file.*--peer-cert-file'", "^[1-9]"]}]}, "fix": {"suggestion": "peer TLS"}},
    {"rule_id": "K8S_2_5", "category": "etcd", "title": "--peer-client-cert-auth=true", "description": "2.5", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep etcd | grep -c -- --peer-client-cert-auth=true", "^[1-9]"]}]}, "fix": {"suggestion": "peer 互信"}},

    {"rule_id": "K8S_3_1_1", "category": "Authentication", "title": "client cert 鉴权", "description": "3.1.1", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --client-ca-file", "^[1-9]"]}]}, "fix": {"suggestion": "--client-ca-file=/etc/kubernetes/pki/ca.crt"}},
    {"rule_id": "K8S_3_2_1", "category": "Logging", "title": "audit policy 已配置", "description": "3.2.1", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- --audit-policy-file", "^[1-9]"]}]}, "fix": {"suggestion": "--audit-policy-file=/etc/kubernetes/audit-policy.yaml"}},

    {"rule_id": "K8S_4_1_1", "category": "Worker Node 文件权限", "title": "kubelet service 文件权限 ≤644", "description": "4.1.1", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_permission", "param": ["/etc/systemd/system/kubelet.service.d/10-kubeadm.conf", "644"]}]}, "fix": {"suggestion": "chmod 644"}},
    {"rule_id": "K8S_4_1_5", "category": "Worker Node 文件权限", "title": "kubelet.conf 权限 ≤644", "description": "4.1.5", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/kubernetes/kubelet.conf", "644"]}]}, "fix": {"suggestion": "chmod 644 kubelet.conf"}},
    {"rule_id": "K8S_4_1_9", "category": "Worker Node 文件权限", "title": "kubelet 配置文件 权限 ≤644", "description": "4.1.9", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/var/lib/kubelet/config.yaml", "644"]}]}, "fix": {"suggestion": "chmod 644"}},

    {"rule_id": "K8S_4_2_1", "category": "Kubelet", "title": "--anonymous-auth=false", "description": "4.2.1", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kubelet | grep -c -- --anonymous-auth=false", "^[1-9]"]}]}, "fix": {"suggestion": "kubelet --anonymous-auth=false"}},
    {"rule_id": "K8S_4_2_2", "category": "Kubelet", "title": "--authorization-mode != AlwaysAllow", "description": "4.2.2", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kubelet | grep -- --authorization-mode | grep -c AlwaysAllow", "^[1-9]"]}]}, "fix": {"suggestion": "--authorization-mode=Webhook"}},
    {"rule_id": "K8S_4_2_3", "category": "Kubelet", "title": "--client-ca-file 已配置", "description": "4.2.3", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kubelet | grep -c -- --client-ca-file", "^[1-9]"]}]}, "fix": {"suggestion": "--client-ca-file=/etc/kubernetes/pki/ca.crt"}},
    {"rule_id": "K8S_4_2_4", "category": "Kubelet", "title": "--read-only-port=0", "description": "4.2.4", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kubelet | grep -c -- --read-only-port=0", "^[1-9]"]}]}, "fix": {"suggestion": "--read-only-port=0"}},
    {"rule_id": "K8S_4_2_6", "category": "Kubelet", "title": "--protect-kernel-defaults=true", "description": "4.2.6", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kubelet | grep -c -- --protect-kernel-defaults=true", "^[1-9]"]}]}, "fix": {"suggestion": "--protect-kernel-defaults=true"}},
    {"rule_id": "K8S_4_2_7", "category": "Kubelet", "title": "--make-iptables-util-chains=true", "description": "4.2.7", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kubelet | grep -c -- --make-iptables-util-chains=true", "^[1-9]"]}]}, "fix": {"suggestion": "默认 true"}},

    {"rule_id": "K8S_5_1_1", "category": "Policies: RBAC", "title": "cluster-admin 权限最小化", "description": "5.1.1", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["kubectl get clusterrolebindings -o json | jq '.items[] | select(.roleRef.name==\"cluster-admin\") | .subjects | length' 2>/dev/null | awk '{s+=$1}END{print s}'", "^[0-5]$"]}]}, "fix": {"suggestion": "cluster-admin 仅授给少数维护账户"}},
    {"rule_id": "K8S_5_1_2", "category": "Policies: RBAC", "title": "default ServiceAccount 不应自动挂载 token", "description": "5.1.2", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["kubectl get serviceaccount default -o json 2>/dev/null | jq '.automountServiceAccountToken'", "false"]}]}, "fix": {"suggestion": "patch sa default automountServiceAccountToken: false"}},
    {"rule_id": "K8S_5_1_5", "category": "Policies: RBAC", "title": "通配符 verb/resources 限制", "description": "5.1.5", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["kubectl get clusterroles -o json | jq '.items[] | select(.rules[]?.verbs[]?==\"*\" and (.metadata.name|startswith(\"system:\")|not)) | .metadata.name' | wc -l", "^[0-3]$"]}]}, "fix": {"suggestion": "审查含 verbs=['*'] 的 ClusterRole, 收紧权限"}},

    {"rule_id": "K8S_5_2_1", "category": "Policies: Pod Security", "title": "PSA 启用 baseline", "description": "5.2.1 PSP 已弃用, 用 PodSecurity admission", "severity": "high", "check": {"condition": "any", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kube-apiserver | grep -c -- '--enable-admission-plugins.*PodSecurity'", "^[1-9]"]}]}, "fix": {"suggestion": "--enable-admission-plugins=PodSecurity,..."}},
    {"rule_id": "K8S_5_2_2", "category": "Policies: Pod Security", "title": "禁 privileged Pod", "description": "5.2.2", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["kubectl get pods -A -o json | jq '.items[] | select(.spec.containers[].securityContext.privileged==true) | .metadata.namespace+\"/\"+.metadata.name' | wc -l", "^0$"]}]}, "fix": {"suggestion": "改用 cap-add 精细权限"}},
    {"rule_id": "K8S_5_2_3", "category": "Policies: Pod Security", "title": "禁 hostPID", "description": "5.2.3", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["kubectl get pods -A -o json | jq '.items[] | select(.spec.hostPID==true) | .metadata.namespace+\"/\"+.metadata.name' | wc -l", "^0$"]}]}, "fix": {"suggestion": "不要 hostPID"}},
