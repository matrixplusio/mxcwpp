{
  "id": "MIDDLEWARE_POSTGRESQL",
  "name": "PostgreSQL 中间件基线 (CIS + 等保 2.0)",
  "version": "1.0.0",
  "description": "PostgreSQL 13/14/15/16 安全基线. 参考 CIS PostgreSQL 16 Benchmark.",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "PG_001", "category": "认证", "title": "pg_hba.conf 禁 trust 远程", "description": "trust 等于无认证, 远程仅允 md5/scram-sha-256/cert", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["grep -v '^#' /var/lib/pgsql/data/pg_hba.conf /etc/postgresql/*/main/pg_hba.conf 2>/dev/null | awk '$1 == \"host\" && $4 != \"127.0.0.1/32\" && $4 != \"::1/128\" && $5 == \"trust\"' | wc -l", "^0$"]}]}, "fix": {"suggestion": "pg_hba.conf 远程行改 md5 或 scram-sha-256"}},
    {"rule_id": "PG_002", "category": "认证", "title": "密码加密算法 scram-sha-256", "description": "弃用 md5 (彩虹表)", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["su - postgres -c \"psql -t -c 'SHOW password_encryption'\" 2>/dev/null | xargs", "scram-sha-256"]}]}, "fix": {"suggestion": "postgresql.conf: password_encryption = scram-sha-256"}},
    {"rule_id": "PG_003", "category": "网络", "title": "listen_addresses 仅内网", "description": "默认 localhost, 远程仅内网 IP", "severity": "high", "check": {"condition": "none", "rules": [{"type": "command_exec", "param": ["grep -E '^\\s*listen_addresses' /var/lib/pgsql/data/postgresql.conf /etc/postgresql/*/main/postgresql.conf 2>/dev/null | grep -c '\\*'", "^0$"]}]}, "fix": {"suggestion": "postgresql.conf: listen_addresses = 'localhost,10.0.0.5' (不用 *)"}},
    {"rule_id": "PG_004", "category": "网络", "title": "SSL 启用", "description": "ssl = on 强制 TLS", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["su - postgres -c \"psql -t -c 'SHOW ssl'\" 2>/dev/null | xargs", "^on$"]}]}, "fix": {"suggestion": "postgresql.conf: ssl=on + ssl_cert_file/ssl_key_file"}},
    {"rule_id": "PG_005", "category": "权限", "title": "数据目录权限 700", "description": "PG_DATA 仅 postgres 用户", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_permission", "param": ["/var/lib/pgsql/data", "700"]}, {"type": "file_permission", "param": ["/var/lib/postgresql/14/main", "700"]}]}, "fix": {"suggestion": "chmod 700 PGDATA && chown -R postgres:postgres"}},
    {"rule_id": "PG_006", "category": "日志", "title": "log_connections = on", "description": "审计连接", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["su - postgres -c \"psql -t -c 'SHOW log_connections'\" 2>/dev/null | xargs", "^on$"]}]}, "fix": {"suggestion": "log_connections = on"}},
    {"rule_id": "PG_007", "category": "日志", "title": "log_disconnections = on", "description": "审计断开", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["su - postgres -c \"psql -t -c 'SHOW log_disconnections'\" 2>/dev/null | xargs", "^on$"]}]}, "fix": {"suggestion": "log_disconnections = on"}},
    {"rule_id": "PG_008", "category": "日志", "title": "log_statement = ddl 或 all", "description": "DDL 操作审计", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["su - postgres -c \"psql -t -c 'SHOW log_statement'\" 2>/dev/null | xargs", "ddl|mod|all"]}]}, "fix": {"suggestion": "log_statement = ddl"}},
    {"rule_id": "PG_009", "category": "用户管理", "title": "无 superuser 非系统账户", "description": "限制 superuser 数量", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["su - postgres -c \"psql -t -c \\\"SELECT count(*) FROM pg_user WHERE usesuper = true AND usename NOT IN ('postgres')\\\"\" 2>/dev/null | xargs", "^[0-1]$"]}]}, "fix": {"suggestion": "REVOKE SUPERUSER FROM <user>"}},
    {"rule_id": "PG_010", "category": "扩展", "title": "禁止 untrusted extension 加载", "description": "防加载恶意 C 扩展", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["su - postgres -c \"psql -t -c 'SHOW shared_preload_libraries'\" 2>/dev/null | xargs | wc -w", ">= 0"]}]}, "fix": {"suggestion": "运维白名单 shared_preload_libraries; CREATE EXTENSION 需 superuser"}}
  ]
}
