{
  "id": "MIDDLEWARE_KAFKA",
  "name": "Apache Kafka 中间件基线 (CIS + 等保 2.0)",
  "version": "1.0.0",
  "description": "Kafka 3.x 安全基线 (KRaft / ZK 通用)",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "KAFKA_001", "category": "认证", "title": "SASL 启用 (PLAINTEXT 不可用)", "description": "broker 必须启 SASL_PLAINTEXT/SASL_SSL 认证", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^listeners=.*SASL", "match"]}]}, "fix": {"suggestion": "listeners=SASL_SSL://0.0.0.0:9093 + security.inter.broker.protocol=SASL_SSL"}},
    {"rule_id": "KAFKA_002", "category": "认证", "title": "PLAINTEXT listener 不暴公网", "description": "如果保留 PLAINTEXT 必须 bind 内网", "severity": "high", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^listeners=.*PLAINTEXT://0\\.0\\.0\\.0:9092", "match"]}]}, "fix": {"suggestion": "PLAINTEXT://127.0.0.1:9092 仅内部用途"}},
    {"rule_id": "KAFKA_003", "category": "授权", "title": "ACL Authorizer 配置", "description": "authorizer.class.name 启用", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^authorizer.class.name=kafka.security.authorizer.AclAuthorizer", "match"]}, {"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^authorizer.class.name=org.apache.kafka.metadata.authorizer.StandardAuthorizer", "match"]}]}, "fix": {"suggestion": "authorizer.class.name=kafka.security.authorizer.AclAuthorizer"}},
    {"rule_id": "KAFKA_004", "category": "授权", "title": "禁用 allow.everyone.if.no.acl.found", "description": "默认 deny 是 SOC 标准", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^allow.everyone.if.no.acl.found=false", "match"]}]}, "fix": {"suggestion": "allow.everyone.if.no.acl.found=false"}},
    {"rule_id": "KAFKA_005", "category": "TLS", "title": "Broker 间 SSL/TLS", "description": "inter-broker 走 TLS", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^security.inter.broker.protocol=SSL", "match"]}, {"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^security.inter.broker.protocol=SASL_SSL", "match"]}]}, "fix": {"suggestion": "security.inter.broker.protocol=SASL_SSL"}},
    {"rule_id": "KAFKA_006", "category": "TLS", "title": "ssl.client.auth=required", "description": "mTLS 双向认证", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/opt/kafka/config/server.properties", "^ssl.client.auth=required", "match"]}]}, "fix": {"suggestion": "ssl.client.auth=required"}},
    {"rule_id": "KAFKA_007", "category": "运行用户", "title": "非 root 启动 (kafka 用户)", "description": "禁止 root 运行", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -o user= -p $(pgrep -f 'kafka.Kafka' | head -1) 2>/dev/null", "^kafka$"]}]}, "fix": {"suggestion": "systemd User=kafka Group=kafka"}},
    {"rule_id": "KAFKA_008", "category": "权限", "title": "server.properties 权限 ≤640", "description": "防口令泄", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/opt/kafka/config/server.properties", "640"]}]}, "fix": {"suggestion": "chmod 640 server.properties && chown kafka:kafka"}},
    {"rule_id": "KAFKA_009", "category": "JMX", "title": "JMX 端口认证", "description": "JMX 默认无认证, 是 RCE 入口", "severity": "critical", "check": {"condition": "any", "rules": [{"type": "command_exec", "param": ["ps -ef | grep kafka.Kafka | grep -v grep", ".*-Dcom.sun.management.jmxremote.authenticate=true.*"]}, {"type": "command_exec", "param": ["ps -ef | grep kafka.Kafka | grep -v grep", "(?!.*jmxremote).*"]}]}, "fix": {"suggestion": "JMX_PORT 必须配 com.sun.management.jmxremote.authenticate=true + ssl=true"}},
    {"rule_id": "KAFKA_010", "category": "日志", "title": "审计日志启用", "description": "log4j2.xml AuthorizerLogger 必须开", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/opt/kafka/config/log4j.properties", "log4j.logger.kafka.authorizer.logger=INFO", "match"]}]}, "fix": {"suggestion": "log4j.logger.kafka.authorizer.logger=INFO,authorizerAppender"}}
  ]
}
