{
  "id": "MIDDLEWARE_MONGODB",
  "name": "MongoDB 中间件基线 (CIS + 等保 2.0)",
  "version": "1.0.0",
  "description": "MongoDB 6.0/7.0 安全基线. 参考 CIS MongoDB 6 Benchmark.",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "MONGO_001", "category": "认证", "title": "auth 启用", "description": "默认无认证, 必须 security.authorization=enabled", "severity": "critical", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/mongod.conf", "authorization:\\s*enabled", "match"]}, {"type": "file_line_match", "param": ["/etc/mongod.conf", "auth\\s*=\\s*true", "match"]}]}, "fix": {"suggestion": "/etc/mongod.conf security.authorization: enabled"}},
    {"rule_id": "MONGO_002", "category": "网络", "title": "bindIp 不绑 0.0.0.0", "description": "默认 127.0.0.1, 远程仅内网", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/etc/mongod.conf", "bindIp:\\s*0\\.0\\.0\\.0", "match"]}, {"type": "file_line_match", "param": ["/etc/mongod.conf", "bind_ip\\s*=\\s*0\\.0\\.0\\.0", "match"]}]}, "fix": {"suggestion": "bindIp: 127.0.0.1,10.0.0.5"}},
    {"rule_id": "MONGO_003", "category": "网络", "title": "TLS/SSL 启用", "description": "传输加密", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/mongod.conf", "tls:.*\\n.*mode:\\s*(requireTLS|preferTLS)", "match"]}, {"type": "file_line_match", "param": ["/etc/mongod.conf", "sslMode:\\s*(requireSSL|preferSSL)", "match"]}]}, "fix": {"suggestion": "net.tls.mode: requireTLS + tls.certificateKeyFile"}},
    {"rule_id": "MONGO_004", "category": "运行用户", "title": "非 root 启动 (mongod)", "description": "mongod 用户", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -o user= -p $(pgrep -f mongod | head -1) 2>/dev/null", "^mongod$|^mongodb$"]}]}, "fix": {"suggestion": "systemd User=mongod"}},
    {"rule_id": "MONGO_005", "category": "权限", "title": "数据目录权限 700", "description": "dbPath 仅 mongod", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_permission", "param": ["/var/lib/mongo", "700"]}, {"type": "file_permission", "param": ["/var/lib/mongodb", "700"]}]}, "fix": {"suggestion": "chmod 700 dbPath && chown mongod:mongod"}},
    {"rule_id": "MONGO_006", "category": "权限", "title": "mongod.conf 权限 ≤644", "description": "配置文件保护", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/mongod.conf", "644"]}]}, "fix": {"suggestion": "chmod 644 /etc/mongod.conf && chown root:mongod"}},
    {"rule_id": "MONGO_007", "category": "审计", "title": "auditLog 启用", "description": "MongoDB Enterprise 审计或 systemLog 详细化", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/mongod.conf", "auditLog:", "match"]}, {"type": "file_line_match", "param": ["/etc/mongod.conf", "verbosity:\\s+[1-9]", "match"]}]}, "fix": {"suggestion": "auditLog.destination: file + auditLog.path"}},
    {"rule_id": "MONGO_008", "category": "审计", "title": "systemLog destination = file", "description": "防 stdout 丢失", "severity": "low", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/mongod.conf", "destination:\\s+file", "match"]}]}, "fix": {"suggestion": "systemLog.destination: file + systemLog.path"}},
    {"rule_id": "MONGO_009", "category": "用户", "title": "禁默认 admin 账户名", "description": "admin/root/test 高风险账户名", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["mongosh --quiet --eval 'db.getSiblingDB(\"admin\").getUsers().filter(u => [\"admin\",\"root\",\"test\"].includes(u.user)).length' 2>/dev/null", "^0$"]}]}, "fix": {"suggestion": "db.createUser({user:'mxsec_admin',...}); db.dropUser('admin')"}},
    {"rule_id": "MONGO_010", "category": "JavaScript", "title": "禁用 server-side JavaScript", "description": "防 NoSQL injection 利用", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/mongod.conf", "javascriptEnabled:\\s*false", "match"]}]}, "fix": {"suggestion": "security.javascriptEnabled: false"}}
  ]
}
