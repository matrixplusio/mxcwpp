{
  "id": "MIDDLEWARE_REDIS",
  "name": "Redis 中间件基线 (CIS + 等保 2.0)",
  "version": "1.0.0",
  "description": "Redis 6.2/7.0 安全基线",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "ubuntu", "debian", "openeuler", "kylin", "uos"],
  "enabled": true,
  "rules": [
    {"rule_id": "REDIS_001", "category": "认证", "title": "强口令 requirepass", "description": "Redis 默认无密码, 必须设强密码", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^requirepass\\s+.{12,}", "match"]}]}, "fix": {"suggestion": "redis.conf: requirepass <12+ 字符强口令>"}},
    {"rule_id": "REDIS_002", "category": "网络", "title": "bind 127.0.0.1 (或内网 IP)", "description": "默认 0.0.0.0 暴露公网严重风险", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^bind\\s+0\\.0\\.0\\.0", "match"]}]}, "fix": {"suggestion": "bind 127.0.0.1 或内网 IP"}},
    {"rule_id": "REDIS_003", "category": "网络", "title": "protected-mode on", "description": "默认 yes, 防未授权访问", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^protected-mode\\s+yes", "match"]}]}, "fix": {"suggestion": "protected-mode yes"}},
    {"rule_id": "REDIS_004", "category": "运行用户", "title": "非 root 启动", "description": "redis 用户启动", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["ps -o user= -p $(pgrep -f 'redis-server' | head -1) 2>/dev/null", "^redis$"]}]}, "fix": {"suggestion": "systemd User=redis"}},
    {"rule_id": "REDIS_005", "category": "命令禁用", "title": "禁用 FLUSHDB/FLUSHALL/CONFIG", "description": "防误删 + 防 config rewrite 攻击", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "rename-command\\s+(FLUSHDB|FLUSHALL|CONFIG)\\s+\"\"", "match"]}]}, "fix": {"suggestion": "rename-command FLUSHALL \"\" / rename-command CONFIG \"\""}},
    {"rule_id": "REDIS_006", "category": "命令禁用", "title": "禁用 EVAL Lua 沙箱逃逸", "description": "高危场景禁用 EVAL", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "rename-command\\s+EVAL\\s+\"\"", "match"]}, {"type": "command_exec", "param": ["redis-cli config get lua-time-limit 2>/dev/null | head -2 | tail -1", "^[0-9]+$"]}]}, "fix": {"suggestion": "如不用 Lua 脚本: rename-command EVAL \"\""}},
    {"rule_id": "REDIS_007", "category": "持久化", "title": "持久化开启 (AOF or RDB)", "description": "防数据丢失", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^appendonly\\s+yes", "match"]}, {"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^save\\s+[0-9]+\\s+[0-9]+", "match"]}]}, "fix": {"suggestion": "appendonly yes 或 save 配置"}},
    {"rule_id": "REDIS_008", "category": "TLS", "title": "TLS 加密通信 (Redis 6+)", "description": "防中间人 + 等保要求", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^tls-port\\s+[0-9]+", "match"]}, {"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^tls-cert-file\\s+/", "match"]}]}, "fix": {"suggestion": "Redis 6+ 启用 TLS: tls-port 6379 + tls-cert-file/tls-key-file"}},
    {"rule_id": "REDIS_009", "category": "权限", "title": "redis.conf 权限 ≤640", "description": "防口令泄露", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/redis/redis.conf", "640"]}]}, "fix": {"suggestion": "chmod 640 /etc/redis/redis.conf && chown redis:redis"}},
    {"rule_id": "REDIS_010", "category": "ACL", "title": "Redis 6+ ACL 用户配置", "description": "默认 default 用户, 推荐细粒度 ACL", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^aclfile\\s+/", "match"]}, {"type": "file_line_match", "param": ["/etc/redis/redis.conf", "^user\\s+\\S+\\s+", "match"]}]}, "fix": {"suggestion": "user app +get +set ~app:* >password"}}
  ]
}
