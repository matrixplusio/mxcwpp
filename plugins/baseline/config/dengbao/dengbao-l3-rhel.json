            ]
          }
        ]
      },
      "fix": {
        "suggestion": "sysctl -w net.ipv4.ip_forward=0",
        "command": "F=/etc/sysctl.d/90-mxsec-baseline.conf; sysctl -w net.ipv4.ip_forward=0 && touch $F && (grep -qE '^\\s*net.ipv4.ip_forward' $F && sed -ri 's|^\\s*net.ipv4.ip_forward.*|net.ipv4.ip_forward = 0|' $F || echo 'net.ipv4.ip_forward = 0' >> $F)"
      }
    },
    {
      "rule_id": "DB_L3_025",
      "category": "入侵防范",
      "title": "启用 SYN Cookies",
