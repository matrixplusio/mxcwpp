        "command": "F=/etc/ssh/sshd_config; cp $F $F.mxbak && (grep -qE '^\\s*#?\\s*MaxAuthTries' $F && sed -ri 's|^\\s*#?\\s*MaxAuthTries.*|MaxAuthTries 4|' $F || echo 'MaxAuthTries 4' >> $F); sshd -t || { mv $F.mxbak $F; exit 1; }",
        "restart_services": [
          "sshd"
        ]
      }
