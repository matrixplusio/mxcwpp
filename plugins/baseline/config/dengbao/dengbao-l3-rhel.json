    {
      "rule_id": "DB_L3_024",
      "category": "入侵防范",
      "title": "禁用 IP 转发",
      "description": "8.1.4.5 网络配置",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "sysctl",
            "param": [
              "net.ipv4.ip_forward",
