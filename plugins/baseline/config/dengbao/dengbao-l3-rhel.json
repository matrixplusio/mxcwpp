        "command": "F=/etc/sysctl.d/90-mxsec-baseline.conf; sysctl -w net.ipv4.tcp_syncookies=1 && touch $F && (grep -qE '^\\s*net.ipv4.tcp_syncookies' $F && sed -ri 's|^\\s*net.ipv4.tcp_syncookies.*|net.ipv4.tcp_syncookies = 1|' $F || echo 'net.ipv4.tcp_syncookies = 1' >> $F)"
      }
