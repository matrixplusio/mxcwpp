{
  "id": "LINUX_DENGBAO_L3_RHEL",
  "name": "等保 2.0 三级基线 - RHEL/CentOS/Rocky/AlmaLinux",
  "version": "1.0.0",
  "description": "GB/T 22239-2019 等保 2.0 三级安全基线. 适用 RHEL 系 OS.",
  "os_family": [
    "centos",
    "rocky",
    "almalinux",
    "rhel",
    "oracle"
  ],
  "enabled": true,
  "rules": [
    {
      "rule_id": "DB_L3_001",
      "category": "身份鉴别",
      "title": "口令最长有效期 ≤90 天",
      "description": "8.1.4.1 用户身份鉴别 - 口令复杂度策略",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_kv",
            "param": [
              "/etc/login.defs",
              "PASS_MAX_DAYS",
              "^([1-8]?[0-9]|90)$"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "echo 'PASS_MAX_DAYS 90' >> /etc/login.defs",
        "command": "F=/etc/login.defs; cp $F $F.mxbak && (grep -qE '^\\s*PASS_MAX_DAYS' $F && sed -ri 's|^\\s*#?\\s*PASS_MAX_DAYS.*|PASS_MAX_DAYS 90|' $F || echo 'PASS_MAX_DAYS 90' >> $F)"
      }
    },
    {
      "rule_id": "DB_L3_002",
      "category": "身份鉴别",
      "title": "口令最短长度 ≥8 字符",
      "description": "8.1.4.1 口令复杂度",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_kv",
            "param": [
              "/etc/login.defs",
              "PASS_MIN_LEN",
              "^([89]|[1-9][0-9]+)$"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "echo 'PASS_MIN_LEN 8' >> /etc/login.defs",
        "command": "F=/etc/login.defs; cp $F $F.mxbak && (grep -qE '^\\s*PASS_MIN_LEN' $F && sed -ri 's|^\\s*#?\\s*PASS_MIN_LEN.*|PASS_MIN_LEN 8|' $F || echo 'PASS_MIN_LEN 8' >> $F)"
      }
    },
    {
      "rule_id": "DB_L3_003",
      "category": "身份鉴别",
      "title": "口令最短修改间隔 ≥1 天",
      "description": "8.1.4.1 防口令频繁修改",
      "severity": "medium",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_kv",
            "param": [
              "/etc/login.defs",
              "PASS_MIN_DAYS",
              "^[1-9][0-9]*$"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "PASS_MIN_DAYS 1",
        "command": "F=/etc/login.defs; cp $F $F.mxbak && (grep -qE '^\\s*PASS_MIN_DAYS' $F && sed -ri 's|^\\s*#?\\s*PASS_MIN_DAYS.*|PASS_MIN_DAYS 1|' $F || echo 'PASS_MIN_DAYS 1' >> $F)"
      }
    },
    {
      "rule_id": "DB_L3_004",
      "category": "身份鉴别",
      "title": "口令过期前提醒 ≥7 天",
      "description": "8.1.4.1 用户感知",
      "severity": "low",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_kv",
            "param": [
              "/etc/login.defs",
              "PASS_WARN_AGE",
              "^([7-9]|[1-9][0-9]+)$"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "PASS_WARN_AGE 7",
        "command": "F=/etc/login.defs; cp $F $F.mxbak && (grep -qE '^\\s*PASS_WARN_AGE' $F && sed -ri 's|^\\s*#?\\s*PASS_WARN_AGE.*|PASS_WARN_AGE 7|' $F || echo 'PASS_WARN_AGE 7' >> $F)"
      }
    },
    {
      "rule_id": "DB_L3_005",
      "category": "身份鉴别",
      "title": "禁止空口令登录",
      "description": "8.1.4.2 强口令",
      "severity": "critical",
      "check": {
        "condition": "none",
        "rules": [
          {
            "type": "file_line_match",
            "param": [
              "/etc/ssh/sshd_config",
              "PermitEmptyPasswords\\s+yes",
              "match"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "PermitEmptyPasswords no in sshd_config",
        "command": "F=/etc/ssh/sshd_config; cp $F $F.mxbak && (grep -qE '^\\s*#?\\s*PermitEmptyPasswords' $F && sed -ri 's|^\\s*#?\\s*PermitEmptyPasswords.*|PermitEmptyPasswords no|' $F || echo 'PermitEmptyPasswords no' >> $F); sshd -t || { mv $F.mxbak $F; exit 1; }",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "DB_L3_006",
      "category": "身份鉴别",
      "title": "登录失败处理 5 次锁定",
      "description": "8.1.4.3 防暴力破解",
      "severity": "high",
      "check": {
        "condition": "any",
        "rules": [
          {
            "type": "file_line_match",
            "param": [
              "/etc/security/faillock.conf",
              "deny\\s*=\\s*[1-5]",
              "match"
            ]
          },
          {
            "type": "file_line_match",
            "param": [
              "/etc/pam.d/system-auth",
              "pam_faillock\\.so.*deny=[1-5]",
              "match"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "faillock.conf: deny=5 unlock_time=600",
        "command": "F=/etc/security/faillock.conf; touch $F; cp $F $F.mxbak && (grep -qE '^\\s*#?\\s*deny' $F && sed -ri 's|^\\s*#?\\s*deny\\s*=.*|deny = 5|' $F || echo 'deny = 5' >> $F) && (grep -qE '^\\s*#?\\s*unlock_time' $F && sed -ri 's|^\\s*#?\\s*unlock_time\\s*=.*|unlock_time = 600|' $F || echo 'unlock_time = 600' >> $F)"
      }
    },
    {
      "rule_id": "DB_L3_007",
      "category": "访问控制",
      "title": "root 不允许直接 SSH 登录",
      "description": "8.1.4.2 最小权限",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_kv",
            "param": [
              "/etc/ssh/sshd_config",
              "PermitRootLogin",
              "^no$"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "PermitRootLogin no in sshd_config",
        "command": "F=/etc/ssh/sshd_config; cp $F $F.mxbak && (grep -qE '^\\s*#?\\s*PermitRootLogin' $F && sed -ri 's|^\\s*#?\\s*PermitRootLogin.*|PermitRootLogin no|' $F || echo 'PermitRootLogin no' >> $F); sshd -t || { mv $F.mxbak $F; exit 1; }",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "DB_L3_008",
      "category": "访问控制",
      "title": "umask 默认 027",
      "description": "8.1.4.3 文件权限",
      "severity": "medium",
      "check": {
        "condition": "any",
        "rules": [
          {
            "type": "file_line_match",
            "param": [
              "/etc/login.defs",
              "UMASK\\s+027",
              "match"
            ]
          },
          {
            "type": "file_line_match",
            "param": [
              "/etc/profile",
              "umask\\s+027",
              "match"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "/etc/login.defs UMASK 027",
        "command": "F=/etc/login.defs; cp $F $F.mxbak && (grep -qE '^\\s*UMASK' $F && sed -ri 's|^\\s*#?\\s*UMASK.*|UMASK 027|' $F || echo 'UMASK 027' >> $F)"
      }
    },
    {
      "rule_id": "DB_L3_009",
      "category": "访问控制",
      "title": "/etc/passwd 权限 644",
      "description": "8.1.4.3 关键文件权限",
      "severity": "medium",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_permission",
            "param": [
              "/etc/passwd",
              "644"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "chmod 644 /etc/passwd",
        "command": "chmod 644 /etc/passwd"
      }
    },
    {
      "rule_id": "DB_L3_010",
      "category": "访问控制",
      "title": "/etc/shadow 权限 ≤640 (RHEL=000)",
      "description": "8.1.4.3",
      "severity": "critical",
      "check": {
        "condition": "any",
        "rules": [
          {
            "type": "file_permission",
            "param": [
              "/etc/shadow",
              "000"
            ]
          },
          {
            "type": "file_permission",
            "param": [
              "/etc/shadow",
              "640"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "chmod 000 /etc/shadow",
        "command": "chmod 000 /etc/shadow"
      }
    },
    {
      "rule_id": "DB_L3_011",
      "category": "安全审计",
      "title": "audit 服务运行",
      "description": "8.1.4.4 安全审计",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "service_status",
            "param": [
              "auditd",
              "active"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "systemctl enable --now auditd",
        "command": "rpm -q audit >/dev/null 2>&1 || { dnf install -y audit >/dev/null 2>&1 || yum install -y audit; }; systemctl enable auditd >/dev/null 2>&1; service auditd restart >/dev/null 2>&1 || systemctl restart auditd >/dev/null 2>&1; systemctl is-active auditd >/dev/null 2>&1",
        "restart_services": []
      }
    },
    {
      "rule_id": "DB_L3_012",
      "category": "安全审计",
      "title": "rsyslog 服务运行",
      "description": "8.1.4.4 日志收集",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "service_status",
            "param": [
              "rsyslog",
              "active"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "systemctl enable --now rsyslog",
        "command": "systemctl enable --now rsyslog"
      }
    },
    {
      "rule_id": "DB_L3_013",
      "category": "安全审计",
      "title": "audit 规则集存在",
      "description": "8.1.4.4 审计规则",
      "severity": "medium",
      "check": {
        "condition": "any",
        "rules": [
          {
            "type": "file_exists",
            "param": [
              "/etc/audit/rules.d/audit.rules"
            ]
          },
          {
            "type": "file_exists",
            "param": [
              "/etc/audit/audit.rules"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "cp /usr/share/doc/audit/rules/30-stig.rules /etc/audit/rules.d/ && augenrules --load",
        "command": "mkdir -p /etc/audit/rules.d && { [ -f /etc/audit/rules.d/audit.rules ] || [ -f /etc/audit/audit.rules ] || printf -- '-D\\n-b 8192\\n-f 1\\n-w /etc/passwd -p wa -k identity\\n-w /etc/shadow -p wa -k identity\\n-w /etc/sudoers -p wa -k scope\\n' > /etc/audit/rules.d/audit.rules; }; command -v augenrules >/dev/null && augenrules --load || true"
      }
    },
    {
      "rule_id": "DB_L3_014",
      "category": "安全审计",
      "title": "审计日志保留 ≥180 天",
      "description": "8.1.4.4 日志保留",
      "severity": "medium",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_kv",
            "param": [
              "/etc/audit/auditd.conf",
              "max_log_file_action",
              "^KEEP_LOGS$"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "max_log_file_action = KEEP_LOGS",
        "command": "rpm -q audit >/dev/null 2>&1 || { dnf install -y audit >/dev/null 2>&1 || yum install -y audit; }; F=/etc/audit/auditd.conf; grep -qs '^log_file' \"$F\" || exit 1; if grep -qE '^[[:space:]]*max_log_file_action' \"$F\"; then sed -ri 's|^[[:space:]]*max_log_file_action.*|max_log_file_action = KEEP_LOGS|' \"$F\"; else echo 'max_log_file_action = KEEP_LOGS' >> \"$F\"; fi",
        "restart_services": [
          "auditd"
        ]
      }
    },
    {
      "rule_id": "DB_L3_015",
      "category": "入侵防范",
      "title": "禁用未使用服务 - rsh",
      "description": "8.1.4.5 最小服务",
      "severity": "high",
      "check": {
        "condition": "none",
        "rules": [
          {
            "type": "package_installed",
            "param": [
              "rsh"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "yum remove rsh-server rsh",
        "command": "(command -v dnf >/dev/null && dnf remove -y rsh rsh-server) || yum remove -y rsh rsh-server"
      }
    },
    {
      "rule_id": "DB_L3_016",
      "category": "入侵防范",
      "title": "禁用未使用服务 - telnet",
      "description": "8.1.4.5 明文协议",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "service_status",
            "param": [
              "telnet.socket",
              "inactive"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "systemctl disable --now telnet.socket",
        "command": "systemctl disable --now telnet.socket 2>/dev/null; systemctl mask telnet.socket 2>/dev/null; true"
      }
    },
    {
      "rule_id": "DB_L3_017",
      "category": "入侵防范",
      "title": "禁用未使用服务 - tftp",
      "description": "8.1.4.5",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "service_status",
            "param": [
              "tftp.socket",
              "inactive"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "systemctl disable --now tftp.socket",
        "command": "systemctl disable --now tftp.socket 2>/dev/null; systemctl mask tftp.socket 2>/dev/null; true"
      }
    },
    {
      "rule_id": "DB_L3_018",
      "category": "入侵防范",
      "title": "禁用 USB 自动挂载",
      "description": "8.1.4.5 介质控制",
      "severity": "medium",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_match",
            "param": [
              "/etc/modprobe.d/usb-storage.conf",
              "install\\s+usb-storage\\s+/bin/true",
              "match"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "echo 'install usb-storage /bin/true' > /etc/modprobe.d/usb-storage.conf",
        "command": "F=/etc/modprobe.d/usb-storage.conf; [ -f $F ] && cp $F $F.mxbak; echo 'install usb-storage /bin/true' > $F"
      }
    },
    {
      "rule_id": "DB_L3_019",
      "category": "入侵防范",
      "title": "SSH Protocol 2",
      "description": "8.1.4.5",
      "severity": "high",
      "check": {
        "condition": "none",
        "rules": [
          {
            "type": "file_line_match",
            "param": [
              "/etc/ssh/sshd_config",
              "^\\s*Protocol\\s+1\\b",
              "match"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "Protocol 2 in sshd_config (or remove line)",
        "command": "F=/etc/ssh/sshd_config; cp $F $F.mxbak && sed -ri 's|^\\s*Protocol\\s+1\\b.*|Protocol 2|' $F; sshd -t || { mv $F.mxbak $F; exit 1; }",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "DB_L3_020",
      "category": "入侵防范",
      "title": "SSH 禁用 X11Forwarding",
      "description": "8.1.4.5",
      "severity": "medium",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_kv",
            "param": [
              "/etc/ssh/sshd_config",
              "X11Forwarding",
              "^no$"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "X11Forwarding no",
        "command": "F=/etc/ssh/sshd_config; cp $F $F.mxbak && (grep -qE '^\\s*#?\\s*X11Forwarding' $F && sed -ri 's|^\\s*#?\\s*X11Forwarding.*|X11Forwarding no|' $F || echo 'X11Forwarding no' >> $F); sshd -t || { mv $F.mxbak $F; exit 1; }",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "DB_L3_021",
      "category": "入侵防范",
      "title": "SSH MaxAuthTries ≤4",
      "description": "8.1.4.5 防暴力破解",
