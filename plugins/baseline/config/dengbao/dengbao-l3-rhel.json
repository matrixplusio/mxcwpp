{
  "id": "LINUX_DENGBAO_L3_RHEL",
  "name": "等保 2.0 三级基线 - RHEL/CentOS/Rocky/AlmaLinux",
  "version": "1.0.0",
  "description": "GB/T 22239-2019 等保 2.0 三级安全基线. 适用 RHEL 系 OS.",
  "os_family": ["centos", "rocky", "almalinux", "rhel", "oracle"],
  "enabled": true,
  "rules": [
    {"rule_id": "DB_L3_001", "category": "身份鉴别", "title": "口令最长有效期 ≤90 天", "description": "8.1.4.1 用户身份鉴别 - 口令复杂度策略", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/login.defs", "PASS_MAX_DAYS", "^([1-8]?[0-9]|90)$"]}]}, "fix": {"suggestion": "echo 'PASS_MAX_DAYS 90' >> /etc/login.defs"}},
    {"rule_id": "DB_L3_002", "category": "身份鉴别", "title": "口令最短长度 ≥8 字符", "description": "8.1.4.1 口令复杂度", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/login.defs", "PASS_MIN_LEN", "^([89]|[1-9][0-9]+)$"]}]}, "fix": {"suggestion": "echo 'PASS_MIN_LEN 8' >> /etc/login.defs"}},
    {"rule_id": "DB_L3_003", "category": "身份鉴别", "title": "口令最短修改间隔 ≥1 天", "description": "8.1.4.1 防口令频繁修改", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/login.defs", "PASS_MIN_DAYS", "^[1-9][0-9]*$"]}]}, "fix": {"suggestion": "PASS_MIN_DAYS 1"}},
    {"rule_id": "DB_L3_004", "category": "身份鉴别", "title": "口令过期前提醒 ≥7 天", "description": "8.1.4.1 用户感知", "severity": "low", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/login.defs", "PASS_WARN_AGE", "^([7-9]|[1-9][0-9]+)$"]}]}, "fix": {"suggestion": "PASS_WARN_AGE 7"}},
    {"rule_id": "DB_L3_005", "category": "身份鉴别", "title": "禁止空口令登录", "description": "8.1.4.2 强口令", "severity": "critical", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/etc/ssh/sshd_config", "PermitEmptyPasswords\\s+yes", "match"]}]}, "fix": {"suggestion": "PermitEmptyPasswords no in sshd_config"}},
    {"rule_id": "DB_L3_006", "category": "身份鉴别", "title": "登录失败处理 5 次锁定", "description": "8.1.4.3 防暴力破解", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/security/faillock.conf", "deny\\s*=\\s*[1-5]", "match"]}, {"type": "file_line_match", "param": ["/etc/pam.d/system-auth", "pam_faillock\\.so.*deny=[1-5]", "match"]}]}, "fix": {"suggestion": "faillock.conf: deny=5 unlock_time=600"}},
    {"rule_id": "DB_L3_007", "category": "访问控制", "title": "root 不允许直接 SSH 登录", "description": "8.1.4.2 最小权限", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/ssh/sshd_config", "PermitRootLogin", "^no$"]}]}, "fix": {"suggestion": "PermitRootLogin no in sshd_config"}},
    {"rule_id": "DB_L3_008", "category": "访问控制", "title": "umask 默认 027", "description": "8.1.4.3 文件权限", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_line_match", "param": ["/etc/login.defs", "UMASK\\s+027", "match"]}, {"type": "file_line_match", "param": ["/etc/profile", "umask\\s+027", "match"]}]}, "fix": {"suggestion": "/etc/login.defs UMASK 027"}},
    {"rule_id": "DB_L3_009", "category": "访问控制", "title": "/etc/passwd 权限 644", "description": "8.1.4.3 关键文件权限", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/passwd", "644"]}]}, "fix": {"suggestion": "chmod 644 /etc/passwd"}},
    {"rule_id": "DB_L3_010", "category": "访问控制", "title": "/etc/shadow 权限 ≤640 (RHEL=000)", "description": "8.1.4.3", "severity": "critical", "check": {"condition": "any", "rules": [{"type": "file_permission", "param": ["/etc/shadow", "000"]}, {"type": "file_permission", "param": ["/etc/shadow", "640"]}]}, "fix": {"suggestion": "chmod 000 /etc/shadow"}},
    {"rule_id": "DB_L3_011", "category": "安全审计", "title": "audit 服务运行", "description": "8.1.4.4 安全审计", "severity": "high", "check": {"condition": "all", "rules": [{"type": "service_status", "param": ["auditd", "active"]}]}, "fix": {"suggestion": "systemctl enable --now auditd"}},
    {"rule_id": "DB_L3_012", "category": "安全审计", "title": "rsyslog 服务运行", "description": "8.1.4.4 日志收集", "severity": "high", "check": {"condition": "all", "rules": [{"type": "service_status", "param": ["rsyslog", "active"]}]}, "fix": {"suggestion": "systemctl enable --now rsyslog"}},
    {"rule_id": "DB_L3_013", "category": "安全审计", "title": "audit 规则集存在", "description": "8.1.4.4 审计规则", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_exists", "param": ["/etc/audit/rules.d/audit.rules"]}, {"type": "file_exists", "param": ["/etc/audit/audit.rules"]}]}, "fix": {"suggestion": "cp /usr/share/doc/audit/rules/30-stig.rules /etc/audit/rules.d/ && augenrules --load"}},
    {"rule_id": "DB_L3_014", "category": "安全审计", "title": "审计日志保留 ≥180 天", "description": "8.1.4.4 日志保留", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/audit/auditd.conf", "max_log_file_action", "^KEEP_LOGS$"]}]}, "fix": {"suggestion": "max_log_file_action = KEEP_LOGS"}},
    {"rule_id": "DB_L3_015", "category": "入侵防范", "title": "禁用未使用服务 - rsh", "description": "8.1.4.5 最小服务", "severity": "high", "check": {"condition": "none", "rules": [{"type": "package_installed", "param": ["rsh"]}]}, "fix": {"suggestion": "yum remove rsh-server rsh"}},
    {"rule_id": "DB_L3_016", "category": "入侵防范", "title": "禁用未使用服务 - telnet", "description": "8.1.4.5 明文协议", "severity": "high", "check": {"condition": "none", "rules": [{"type": "service_status", "param": ["telnet.socket", "inactive"]}]}, "fix": {"suggestion": "systemctl disable --now telnet.socket"}},
    {"rule_id": "DB_L3_017", "category": "入侵防范", "title": "禁用未使用服务 - tftp", "description": "8.1.4.5", "severity": "high", "check": {"condition": "none", "rules": [{"type": "service_status", "param": ["tftp.socket", "inactive"]}]}, "fix": {"suggestion": "systemctl disable --now tftp.socket"}},
    {"rule_id": "DB_L3_018", "category": "入侵防范", "title": "禁用 USB 自动挂载", "description": "8.1.4.5 介质控制", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/modprobe.d/usb-storage.conf", "install\\s+usb-storage\\s+/bin/true", "match"]}]}, "fix": {"suggestion": "echo 'install usb-storage /bin/true' > /etc/modprobe.d/usb-storage.conf"}},
    {"rule_id": "DB_L3_019", "category": "入侵防范", "title": "SSH Protocol 2", "description": "8.1.4.5", "severity": "high", "check": {"condition": "none", "rules": [{"type": "file_line_match", "param": ["/etc/ssh/sshd_config", "^\\s*Protocol\\s+1\\b", "match"]}]}, "fix": {"suggestion": "Protocol 2 in sshd_config (or remove line)"}},
    {"rule_id": "DB_L3_020", "category": "入侵防范", "title": "SSH 禁用 X11Forwarding", "description": "8.1.4.5", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/ssh/sshd_config", "X11Forwarding", "^no$"]}]}, "fix": {"suggestion": "X11Forwarding no"}},
    {"rule_id": "DB_L3_021", "category": "入侵防范", "title": "SSH MaxAuthTries ≤4", "description": "8.1.4.5 防暴力破解", "severity": "high", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/ssh/sshd_config", "MaxAuthTries", "^[1-4]$"]}]}, "fix": {"suggestion": "MaxAuthTries 4"}},
    {"rule_id": "DB_L3_022", "category": "入侵防范", "title": "SSH ClientAliveInterval ≤300", "description": "8.1.4.5 空闲会话超时", "severity": "low", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/ssh/sshd_config", "ClientAliveInterval", "^([1-9]|[1-9][0-9]|[12][0-9][0-9]|300)$"]}]}, "fix": {"suggestion": "ClientAliveInterval 300"}},
    {"rule_id": "DB_L3_023", "category": "入侵防范", "title": "SSH LoginGraceTime ≤60", "description": "8.1.4.5", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_kv", "param": ["/etc/ssh/sshd_config", "LoginGraceTime", "^([1-9]|[1-5][0-9]|60)$"]}]}, "fix": {"suggestion": "LoginGraceTime 60"}},
    {"rule_id": "DB_L3_024", "category": "入侵防范", "title": "禁用 IP 转发", "description": "8.1.4.5 网络配置", "severity": "high", "check": {"condition": "all", "rules": [{"type": "sysctl", "param": ["net.ipv4.ip_forward", "0"]}]}, "fix": {"suggestion": "sysctl -w net.ipv4.ip_forward=0"}},
    {"rule_id": "DB_L3_025", "category": "入侵防范", "title": "启用 SYN Cookies", "description": "8.1.4.5 抗 DoS", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "sysctl", "param": ["net.ipv4.tcp_syncookies", "1"]}]}, "fix": {"suggestion": "sysctl -w net.ipv4.tcp_syncookies=1"}},
    {"rule_id": "DB_L3_026", "category": "入侵防范", "title": "禁用 ICMP redirect", "description": "8.1.4.5", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "sysctl", "param": ["net.ipv4.conf.all.accept_redirects", "0"]}]}, "fix": {"suggestion": "sysctl -w net.ipv4.conf.all.accept_redirects=0"}},
    {"rule_id": "DB_L3_027", "category": "恶意代码", "title": "ClamAV 已安装", "description": "8.1.4.6 防病毒", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "package_installed", "param": ["clamav"]}, {"type": "service_status", "param": ["clamav-daemon", "active"]}]}, "fix": {"suggestion": "yum install clamav clamd && systemctl enable --now clamd"}},
    {"rule_id": "DB_L3_028", "category": "恶意代码", "title": "病毒库 ≤7 天", "description": "8.1.4.6 病毒库及时", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["find /var/lib/clamav/main.cvd -mtime -7 2>/dev/null | wc -l", "^[1-9]"]}]}, "fix": {"suggestion": "freshclam"}},
    {"rule_id": "DB_L3_029", "category": "数据完整性", "title": "AIDE 文件完整性已配置", "description": "8.1.4.7 数据完整性", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "package_installed", "param": ["aide"]}, {"type": "file_exists", "param": ["/var/lib/aide/aide.db.gz"]}]}, "fix": {"suggestion": "yum install aide && aide --init"}},
    {"rule_id": "DB_L3_030", "category": "数据完整性", "title": "AIDE 周期检查 cron", "description": "8.1.4.7 周期检查", "severity": "low", "check": {"condition": "any", "rules": [{"type": "file_exists", "param": ["/etc/cron.daily/aide"]}, {"type": "file_exists", "param": ["/etc/cron.weekly/aide"]}]}, "fix": {"suggestion": "echo '0 5 * * * /usr/sbin/aide --check' > /etc/cron.d/aide"}},
    {"rule_id": "DB_L3_031", "category": "数据保密", "title": "/tmp 独立分区", "description": "8.1.4.8 隔离临时文件", "severity": "low", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["mount | grep -E '\\s+/tmp\\s+' | wc -l", "^[1-9]"]}]}, "fix": {"suggestion": "新增 /tmp 独立分区 (LVM/规划阶段)"}},
    {"rule_id": "DB_L3_032", "category": "数据保密", "title": "/tmp nodev,nosuid,noexec", "description": "8.1.4.8", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["mount | grep -E '\\s+/tmp\\s+' | grep -c 'nodev.*nosuid.*noexec'", "^[1-9]"]}]}, "fix": {"suggestion": "/etc/fstab /tmp 加 nodev,nosuid,noexec"}},
    {"rule_id": "DB_L3_033", "category": "访问控制", "title": "/etc/passwd 无空口令账户", "description": "8.1.4.2", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["awk -F: '($2 == \"\") {print}' /etc/shadow | wc -l", "^0$"]}]}, "fix": {"suggestion": "passwd -l <user> 锁定空口令账户"}},
    {"rule_id": "DB_L3_034", "category": "访问控制", "title": "无 UID=0 非 root 账户", "description": "8.1.4.2 唯一 root", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["awk -F: '($3==0) {print $1}' /etc/passwd | grep -v '^root$' | wc -l", "^0$"]}]}, "fix": {"suggestion": "userdel <user> 或 改 UID"}},
    {"rule_id": "DB_L3_035", "category": "访问控制", "title": "root crontab 限制", "description": "8.1.4.3", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_permission", "param": ["/etc/crontab", "600"]}]}, "fix": {"suggestion": "chmod 600 /etc/crontab"}},
    {"rule_id": "DB_L3_036", "category": "访问控制", "title": "GRUB 配置文件权限 600", "description": "8.1.4.3 防 启动篡改", "severity": "high", "check": {"condition": "any", "rules": [{"type": "file_permission", "param": ["/boot/grub2/grub.cfg", "600"]}, {"type": "file_permission", "param": ["/boot/grub/grub.cfg", "600"]}]}, "fix": {"suggestion": "chmod 600 /boot/grub2/grub.cfg"}},
    {"rule_id": "DB_L3_037", "category": "入侵防范", "title": "防火墙 firewalld 启用", "description": "8.1.4.5", "severity": "high", "check": {"condition": "any", "rules": [{"type": "service_status", "param": ["firewalld", "active"]}, {"type": "service_status", "param": ["iptables", "active"]}, {"type": "service_status", "param": ["nftables", "active"]}]}, "fix": {"suggestion": "systemctl enable --now firewalld"}},
    {"rule_id": "DB_L3_038", "category": "入侵防范", "title": "SELinux Enforcing", "description": "8.1.4.5 强制访问控制", "severity": "high", "check": {"condition": "all", "rules": [{"type": "command_exec", "param": ["getenforce 2>/dev/null", "^Enforcing$"]}]}, "fix": {"suggestion": "setenforce 1 && sed -i 's/^SELINUX=.*/SELINUX=enforcing/' /etc/selinux/config"}},
    {"rule_id": "DB_L3_039", "category": "安全审计", "title": "登录失败日志记录", "description": "8.1.4.4", "severity": "medium", "check": {"condition": "any", "rules": [{"type": "file_exists", "param": ["/var/log/secure"]}, {"type": "file_exists", "param": ["/var/log/auth.log"]}]}, "fix": {"suggestion": "rsyslog 配置 authpriv.* /var/log/secure"}},
    {"rule_id": "DB_L3_040", "category": "安全审计", "title": "wheel 组 sudo 限制", "description": "8.1.4.3 sudo 控制", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "file_line_match", "param": ["/etc/sudoers", "^\\s*%wheel\\s+ALL", "match"]}]}, "fix": {"suggestion": "visudo: %wheel ALL=(ALL) ALL"}}
  ]
}
