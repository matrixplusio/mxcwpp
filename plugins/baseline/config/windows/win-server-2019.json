{
  "id": "WINDOWS_SERVER_2019_DENGBAO",
  "name": "Windows Server 2019/2022 基线 (CIS + 等保 2.0)",
  "version": "1.0.0",
  "description": "Windows Server 2019/2022 安全基线. 参考 CIS Microsoft Windows Server 2019 Benchmark v1.3.0 + GB/T 22239-2019 等保 2.0 三级.",
  "os_family": ["windows"],
  "os_version": ">=10.0.17763",
  "enabled": true,
  "rules": [
    {"rule_id": "WIN_001", "category": "账户策略", "title": "口令最长有效期 ≤90 天", "description": "等保 8.1.4.1 + CIS 1.1.1", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["net accounts | Select-String 'Maximum password age.*(?<days>\\d+) days'", "max_days <= 90"]}]}, "fix": {"suggestion": "net accounts /maxpwage:90"}},
    {"rule_id": "WIN_002", "category": "账户策略", "title": "口令最短长度 ≥8", "description": "CIS 1.1.4", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["(secedit /export /cfg \"$env:TEMP\\sec.cfg\"; Select-String -Path \"$env:TEMP\\sec.cfg\" -Pattern 'MinimumPasswordLength' | %{$_.Line})", "MinimumPasswordLength\\s*=\\s*([89]|[1-9][0-9]+)"]}]}, "fix": {"suggestion": "secedit/gpedit: 最小密码长度 = 8"}},
    {"rule_id": "WIN_003", "category": "账户策略", "title": "口令复杂度启用", "description": "CIS 1.1.5", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["secedit /export /cfg \"$env:TEMP\\sec.cfg\"; Select-String -Path \"$env:TEMP\\sec.cfg\" -Pattern 'PasswordComplexity'", "PasswordComplexity\\s*=\\s*1"]}]}, "fix": {"suggestion": "gpedit 启用密码复杂度"}},
    {"rule_id": "WIN_004", "category": "账户策略", "title": "5 次失败锁定 (30 分钟)", "description": "等保 8.1.4.1", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["net accounts | Select-String 'Lockout threshold'", "Lockout threshold:\\s+[1-5]"]}]}, "fix": {"suggestion": "net accounts /lockoutthreshold:5 /lockoutduration:30"}},
    {"rule_id": "WIN_005", "category": "账户策略", "title": "禁用 Guest 账户", "description": "CIS 2.3.1.5", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-LocalUser Guest | Select-Object -ExpandProperty Enabled", "False"]}]}, "fix": {"suggestion": "Disable-LocalUser -Name Guest"}},
    {"rule_id": "WIN_006", "category": "账户策略", "title": "禁用 Administrator 账户 (改名)", "description": "CIS 2.3.1.6 - 默认 admin 改名防爆破", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-LocalUser | Where-Object {$_.SID -like 'S-1-5-21-*-500'} | Select-Object -ExpandProperty Name", "^(?!Administrator$).+"]}]}, "fix": {"suggestion": "Rename-LocalUser -Name Administrator -NewName <newname>"}},
    {"rule_id": "WIN_007", "category": "审计策略", "title": "审计登录事件", "description": "CIS 17.5 / 等保 8.1.4.4", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["auditpol /get /subcategory:'Logon' /r | Select-String 'Success and Failure'", "Success and Failure"]}]}, "fix": {"suggestion": "auditpol /set /subcategory:'Logon' /success:enable /failure:enable"}},
    {"rule_id": "WIN_008", "category": "审计策略", "title": "审计账户登录事件", "description": "CIS 17.1", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["auditpol /get /subcategory:'Credential Validation' /r | Select-String 'Success and Failure'", "Success and Failure"]}]}, "fix": {"suggestion": "auditpol /set /subcategory:'Credential Validation' /success:enable /failure:enable"}},
    {"rule_id": "WIN_009", "category": "审计策略", "title": "审计权限变更", "description": "CIS 17.4", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["auditpol /get /subcategory:'Authentication Policy Change' /r", "Success and Failure|Success"]}]}, "fix": {"suggestion": "auditpol /set /category:'Policy Change' /success:enable /failure:enable"}},
    {"rule_id": "WIN_010", "category": "审计策略", "title": "事件日志保留 ≥180 天", "description": "等保 8.1.4.4 数据保留", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["(Get-WinEvent -ListLog Security).MaximumSizeInBytes / 1MB", ">= 1024"]}]}, "fix": {"suggestion": "wevtutil sl Security /ms:1073741824"}},
    {"rule_id": "WIN_011", "category": "网络配置", "title": "禁用 NetBIOS over TCP/IP", "description": "CIS 18.4 + 减少攻击面", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\System\\CurrentControlSet\\Services\\NetBT\\Parameters\\Interfaces", "NetbiosOptions", "= 2"]}]}, "fix": {"suggestion": "PowerShell: Set-ItemProperty 各 Interface NetbiosOptions=2"}},
    {"rule_id": "WIN_012", "category": "网络配置", "title": "禁用 LM/NTLMv1", "description": "CIS 2.3.11 - 仅 NTLMv2", "severity": "high", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa", "LmCompatibilityLevel", ">= 5"]}]}, "fix": {"suggestion": "Set-ItemProperty -Path HKLM:\\SYSTEM\\CurrentControlSet\\Control\\Lsa -Name LmCompatibilityLevel -Value 5"}},
    {"rule_id": "WIN_013", "category": "网络配置", "title": "禁用 SMBv1", "description": "CIS 18.3 - WannaCry 教训", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-SmbServerConfiguration | Select-Object -ExpandProperty EnableSMB1Protocol", "False"]}]}, "fix": {"suggestion": "Set-SmbServerConfiguration -EnableSMB1Protocol $false -Force"}},
    {"rule_id": "WIN_014", "category": "网络配置", "title": "SMB 签名要求", "description": "CIS 2.3.8.1", "severity": "high", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\System\\CurrentControlSet\\Services\\LanmanWorkstation\\Parameters", "RequireSecuritySignature", "= 1"]}]}, "fix": {"suggestion": "Set-SmbClientConfiguration -RequireSecuritySignature $true"}},
    {"rule_id": "WIN_015", "category": "防火墙", "title": "Windows Defender Firewall 三 profile 启用", "description": "CIS 9.1.1/9.2.1/9.3.1", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-NetFirewallProfile | Where-Object {$_.Enabled -ne 'True'} | Measure-Object | Select-Object -ExpandProperty Count", "^0$"]}]}, "fix": {"suggestion": "Set-NetFirewallProfile -Profile Domain,Public,Private -Enabled True"}},
    {"rule_id": "WIN_016", "category": "防火墙", "title": "入站默认 Block", "description": "CIS 9.1.2 - 默认拒绝", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-NetFirewallProfile | Select-Object -ExpandProperty DefaultInboundAction | Get-Unique", "Block"]}]}, "fix": {"suggestion": "Set-NetFirewallProfile -DefaultInboundAction Block"}},
    {"rule_id": "WIN_017", "category": "Defender", "title": "Defender 实时保护启用", "description": "CIS 18.9.45 + 反病毒", "severity": "critical", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-MpPreference | Select-Object -ExpandProperty DisableRealtimeMonitoring", "False"]}]}, "fix": {"suggestion": "Set-MpPreference -DisableRealtimeMonitoring $false"}},
    {"rule_id": "WIN_018", "category": "Defender", "title": "Defender 病毒库 ≤7 天", "description": "等保 8.1.4.6 病毒库及时", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["((Get-Date) - (Get-MpComputerStatus).AntivirusSignatureLastUpdated).TotalDays", "<= 7"]}]}, "fix": {"suggestion": "Update-MpSignature"}},
    {"rule_id": "WIN_019", "category": "Defender", "title": "Tamper Protection 启用", "description": "Windows 11 / Server 2022 防卸载", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-MpPreference | Select-Object -ExpandProperty TamperProtectionSource", "Tamper|Protected"]}]}, "fix": {"suggestion": "Defender Security Center 启用 Tamper Protection"}},
    {"rule_id": "WIN_020", "category": "服务", "title": "禁用 Telnet 服务", "description": "明文协议", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-Service -Name TlntSvr -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Status", "(?!Running)|^$"]}]}, "fix": {"suggestion": "Set-Service -Name TlntSvr -StartupType Disabled"}},
    {"rule_id": "WIN_021", "category": "服务", "title": "禁用 Print Spooler (域控)", "description": "CIS 5.27 - PrintNightmare", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["if ((Get-WindowsFeature -Name AD-Domain-Services).Installed) { Get-Service Spooler | Select-Object -ExpandProperty Status } else { 'NotDC' }", "Stopped|NotDC"]}]}, "fix": {"suggestion": "域控: Stop-Service Spooler; Set-Service Spooler -StartupType Disabled"}},
    {"rule_id": "WIN_022", "category": "服务", "title": "禁用 Remote Registry", "description": "CIS 5.34", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-Service RemoteRegistry | Select-Object -ExpandProperty StartType", "Disabled"]}]}, "fix": {"suggestion": "Set-Service RemoteRegistry -StartupType Disabled"}},
    {"rule_id": "WIN_023", "category": "RDP", "title": "RDP 启用 NLA", "description": "CIS 18.9.65 - 防中间人", "severity": "high", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SYSTEM\\CurrentControlSet\\Control\\Terminal Server\\WinStations\\RDP-Tcp", "UserAuthentication", "= 1"]}]}, "fix": {"suggestion": "Set-ItemProperty 'HKLM:\\...\\RDP-Tcp' UserAuthentication 1"}},
    {"rule_id": "WIN_024", "category": "RDP", "title": "RDP 加密级别 = High", "description": "CIS 18.9.65", "severity": "high", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SYSTEM\\CurrentControlSet\\Control\\Terminal Server\\WinStations\\RDP-Tcp", "MinEncryptionLevel", ">= 3"]}]}, "fix": {"suggestion": "MinEncryptionLevel = 3 (High)"}},
    {"rule_id": "WIN_025", "category": "RDP", "title": "RDP 端口非默认 (推荐)", "description": "改 3389 → 自定义", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SYSTEM\\CurrentControlSet\\Control\\Terminal Server\\WinStations\\RDP-Tcp", "PortNumber", "!= 3389"]}]}, "fix": {"suggestion": "PortNumber = 自定义 + 防火墙规则同步"}},
    {"rule_id": "WIN_026", "category": "UAC", "title": "UAC 启用", "description": "CIS 2.3.17", "severity": "high", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "EnableLUA", "= 1"]}]}, "fix": {"suggestion": "EnableLUA = 1"}},
    {"rule_id": "WIN_027", "category": "UAC", "title": "UAC 管理员提示模式", "description": "CIS 2.3.17.1", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "ConsentPromptBehaviorAdmin", "= 2"]}]}, "fix": {"suggestion": "ConsentPromptBehaviorAdmin = 2 (始终提示)"}},
    {"rule_id": "WIN_028", "category": "PowerShell", "title": "PowerShell ScriptBlock Logging", "description": "审计 + 蓝队取证", "severity": "medium", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\PowerShell\\ScriptBlockLogging", "EnableScriptBlockLogging", "= 1"]}]}, "fix": {"suggestion": "gpedit: 启用 PowerShell ScriptBlock Logging"}},
    {"rule_id": "WIN_029", "category": "BitLocker", "title": "BitLocker 系统盘加密", "description": "数据保密性", "severity": "high", "check": {"condition": "all", "rules": [{"type": "powershell_check", "param": ["Get-BitLockerVolume -MountPoint C: | Select-Object -ExpandProperty ProtectionStatus", "On"]}]}, "fix": {"suggestion": "Enable-BitLocker -MountPoint C: -EncryptionMethod XtsAes256 -UsedSpaceOnly -TpmProtector"}},
    {"rule_id": "WIN_030", "category": "更新", "title": "自动更新启用", "description": "CIS 18.9.108 + 等保补丁及时", "severity": "high", "check": {"condition": "all", "rules": [{"type": "registry_check", "param": ["HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\WindowsUpdate\\AU", "NoAutoUpdate", "= 0"]}]}, "fix": {"suggestion": "NoAutoUpdate = 0; AUOptions = 4 (自动下载+安装)"}}
  ]
}
