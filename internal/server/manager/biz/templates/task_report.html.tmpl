<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{.Meta.Title}}</title>
<style>
  /* ============== Page setup ============== */
  @page {
    size: A4;
    margin: 14mm 12mm 16mm 12mm;
    @bottom-center {
      content: counter(page) " / " counter(pages);
      font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: 10px;
      color: #64748B;
    }
    @bottom-left {
      content: "矩阵云安全平台 · 任务执行报告";
      font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: 9px;
      color: #94A3B8;
    }
    @bottom-right {
      content: "机密 · 仅限内部使用";
      font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: 9px;
      color: #E5484D;
    }
  }
  @page :first {
    margin: 0;
    @bottom-center { content: none; }
    @bottom-left { content: none; }
    @bottom-right { content: none; }
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0; padding: 0;
    font-family: "PingFang SC", "Microsoft YaHei", "Helvetica Neue", Arial, sans-serif;
    color: #0F172A;
    font-size: 14px;
    line-height: 1.75;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* ============== Cover ============== */
  .cover {
    width: 100vw;
    height: 100vh;
    min-height: 100vh;
    padding: 28mm 22mm 24mm 22mm;
    background:
      radial-gradient(ellipse at top right, rgba(79,125,249,0.07) 0%, transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(37,99,235,0.08) 0%, transparent 50%),
      #ffffff;
    display: grid;
    grid-template-rows: auto 1fr auto;
    row-gap: 0;
    page-break-after: always;
    position: relative;
    box-sizing: border-box;
    overflow: hidden;
  }
  .cover-meta { align-self: end; }
  .cover::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 6px;
    background: linear-gradient(180deg, #2563EB 0%, #4F7DF9 100%);
  }
  .cover-brand { display: flex; align-items: center; gap: 18px; }
  .cover-brand img { width: 64px; height: 64px; }
  .cover-brand-name {
    font-size: 22px; font-weight: 600; color: #0F172A; line-height: 1.2;
    letter-spacing: 2px;
  }
  .cover-brand-en {
    font-size: 12px; color: #64748B;
    font-family: "JetBrains Mono", Consolas, monospace; margin-top: 4px;
    letter-spacing: 1px;
  }

  .cover-mid {
    display: flex; flex-direction: column;
    justify-content: center; align-items: center; text-align: center;
    min-height: 0;
  }
  .cover-kind {
    font-size: 20px; letter-spacing: 10px; color: #2563EB;
    font-weight: 500; margin-bottom: 24px;
  }
  .cover-title {
    font-size: 60px; font-weight: 700; letter-spacing: 10px;
    background: linear-gradient(135deg, #2563EB 0%, #4F7DF9 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 0 0 30px 0;
  }
  .cover-period {
    font-size: 19px; color: #0F172A;
    padding: 10px 28px; border: 1px solid #E9EDF3; border-radius: 999px;
    background: #ffffff;
  }
  .cover-deco {
    margin-top: 22px;
    width: 240px; height: 4px;
    background: linear-gradient(90deg, transparent, #2563EB, #4F7DF9, transparent);
  }

  /* 亮点四列 */
  .cover-highlights {
    margin-top: 36px;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
    width: 100%;
  }
  .cover-highlights .hl {
    padding: 14px 10px;
    border: 1px solid #E9EDF3;
    border-top: 3px solid #2563EB;
    border-radius: 6px;
    background: #ffffff;
    text-align: center;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .cover-highlights .hl.hl-c { border-top-color: #E5484D; }
  .cover-highlights .hl.hl-b { border-top-color: #F59E0B; }
  .cover-highlights .hl.hl-p { border-top-color: #4F7DF9; }
  .cover-highlights .hl.hl-g { border-top-color: #16A34A; }
  .cover-highlights .hl-num {
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 26px; font-weight: 700; color: #0F172A;
    letter-spacing: -0.5px; line-height: 1.1;
  }
  .cover-highlights .hl-lbl {
    font-size: 11.5px; color: #64748B; margin-top: 4px;
  }

  /* 本期摘要 */
  .cover-summary {
    margin-top: 28px;
    width: 100%;
    padding: 16px 18px;
    border-left: 4px solid #2563EB;
    background: linear-gradient(90deg, rgba(37,99,235,0.04) 0%, transparent 100%);
    border-radius: 4px;
  }
  .cover-summary-title {
    font-size: 15px; font-weight: 600; color: #2563EB;
    margin-bottom: 8px; letter-spacing: 2px;
  }
  .cover-summary-text {
    font-size: 14px; color: #0F172A; line-height: 1.9;
    text-align: justify;
  }

  .cover-meta {
    border-top: 2px solid #E9EDF3;
    padding-top: 22px;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px 40px;
    font-size: 14.5px;
  }
  .cover-meta-row { display: flex; justify-content: space-between; }
  .cover-meta-label { color: #64748B; }
  .cover-meta-value { font-family: "JetBrains Mono", Consolas, monospace; font-weight: 500; color: #0F172A; }
  .cover-class {
    grid-column: span 2; margin-top: 16px; text-align: center;
    color: #E5484D; font-weight: 600; letter-spacing: 5px;
    font-size: 15px;
    padding: 8px;
    border: 1px solid rgba(229, 72, 77, 0.2);
    background: rgba(229, 72, 77, 0.04);
    border-radius: 4px;
  }

  /* ============== Page ============== */
  .page {
    padding: 0 2mm;
  }
  .force-break { page-break-before: always; break-before: page; }

  /* TOC */
  .toc.page {
    box-sizing: border-box;
    padding: 12mm 12mm 14mm 12mm;
    display: flex; flex-direction: column;
  }
  .toc h2 { text-align: center; letter-spacing: 16px; font-size: 30px; margin: 0 0 6mm 0; color: #0F172A; }
  .toc .toc-list { list-style: none; padding: 0; margin: 0; counter-reset: toc; max-width: 170mm; margin-left: auto; margin-right: auto; width: 100%; }
  .toc .toc-list > li {
    counter-increment: toc;
    display: flex; align-items: baseline;
    padding: 6px 0; border-bottom: 1px dotted #E9EDF3;
    font-size: 15.5px;
  }
  .toc .toc-list > li::before {
    content: counter(toc) ".";
    color: #2563EB; font-family: "JetBrains Mono", Consolas, monospace;
    font-weight: 600; min-width: 32px; font-size: 16px;
  }
  .toc-title { flex: 1; }
  .toc-page { color: #64748B; font-family: "JetBrains Mono", Consolas, monospace; font-size: 14px; }
  .toc-hint {
    margin: 4mm auto 0; max-width: 170mm; padding: 10px 14px;
    background: #F8FAFC; border-left: 3px solid #2563EB;
    font-size: 12.5px; color: #64748B; line-height: 1.7;
  }
  .toc-extra { max-width: 170mm; margin: 5mm auto 0; width: 100%; }
  .toc-block { margin-bottom: 5mm; }
  .toc-block-title {
    font-size: 16px; font-weight: 600; color: #0F172A;
    margin-bottom: 6px; padding-left: 10px;
    border-left: 3px solid #4F7DF9;
  }
  .toc-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
  .toc-table td {
    padding: 6px 12px;
    border-bottom: 1px solid #E9EDF3;
  }
  .toc-table td:first-child {
    width: 28%; color: #64748B; font-weight: 500;
  }
  .toc-table td:last-child { color: #0F172A; }
  .toc-guide { margin: 0; padding-left: 22px; font-size: 13.5px; line-height: 1.8; color: #0F172A; }
  .toc-guide li { margin-bottom: 3px; }
  .toc-guide b { color: #2563EB; }
  .toc-footer {
    margin-top: auto; padding-top: 8px;
    border-top: 1px dashed #E9EDF3;
    text-align: center;
    font-size: 11.5px; color: #94A3B8;
    letter-spacing: 1.5px;
  }

  /* Section heading */
  h2.sec {
    font-size: 22px; font-weight: 600;
    margin: 18px 0 12px 0; padding-bottom: 7px;
    border-bottom: 2px solid #2563EB;
    page-break-after: avoid;
    break-after: avoid;
    color: #0F172A;
  }
  h2.sec:first-of-type { margin-top: 6px; }
  h2.sec + p,
  h2.sec + .stat-row,
  h2.sec + table.t,
  h2.sec + .fig,
  h2.sec + h3.subsec,
  h2.sec + ul,
  h2.sec + ol {
    page-break-before: avoid;
    break-before: avoid;
  }
  h3.subsec {
    font-size: 17px; font-weight: 600;
    margin: 16px 0 9px 0; padding-left: 11px;
    border-left: 4px solid #4F7DF9;
    page-break-after: avoid;
    break-after: avoid;
    color: #0F172A;
  }
  h3.subsec + table.t,
  h3.subsec + p,
  h3.subsec + .fig {
    page-break-before: avoid;
    break-before: avoid;
  }
  p { margin: 0 0 12px 0; text-indent: 2em; text-align: justify; line-height: 1.85; font-size: 14.5px; }
  p.no-indent { text-indent: 0; }
  ul, ol { margin: 6px 0 14px 0; padding-left: 26px; font-size: 14.5px; line-height: 1.9; }
  ul li, ol li { margin-bottom: 6px; }
  b, strong { color: #0F172A; font-weight: 600; }

  /* Tables */
  table.t {
    width: 100%; border-collapse: collapse; font-size: 13.5px;
    margin: 8px 0 14px 0;
  }
  table.t thead th {
    background: #F8FAFC; color: #0F172A;
    text-align: left; padding: 9px 12px;
    border-top: 1px solid #E9EDF3;
    border-bottom: 2px solid #2563EB;
    font-weight: 600;
    font-size: 14px;
  }
  table.t tbody td {
    padding: 8px 12px;
    border-bottom: 1px solid #E9EDF3;
    vertical-align: top;
  }
  table.t tbody tr:nth-child(even) td { background: #F8FAFC; }
  table.t tr { page-break-inside: avoid; }
  td.num, th.num { text-align: right; font-family: "JetBrains Mono", Consolas, monospace; font-variant-numeric: tabular-nums; }
  td.code { font-family: "JetBrains Mono", Consolas, monospace; font-size: 12.5px; word-break: break-all; }
  td.empty { text-align: center; color: #94A3B8; font-style: italic; padding: 16px; }

  .sev-pill { display: inline-block; padding: 2px 9px; border-radius: 3px; font-size: 12px; font-weight: 500; }
  .sev-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 7px; vertical-align: middle; }

  /* 2 列 layout */
  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin: 8px 0 10px 0; }
  .row2 > * { min-width: 0; }
  .row2 h3.subsec:first-of-type { margin-top: 0; }
  .row1 { display: block; margin: 8px 0 10px 0; }

  /* figure */
  .fig { margin: 10px 0 14px 0; page-break-inside: avoid; text-align: center; }
  .fig svg { max-width: 100%; height: auto; }
  .fig-cap { margin-top: 4px; font-size: 13px; color: #64748B; letter-spacing: 1px; }

  .empty-block { color: #94A3B8; font-style: italic; padding: 12px 0; font-size: 14px; }

  /* 紧凑卡片 */
  .stat-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
    margin: 10px 0 14px 0;
  }
  .stat-row .cell {
    border: 1px solid #E9EDF3; border-left: 4px solid #2563EB;
    padding: 12px 14px; border-radius: 4px;
    background: linear-gradient(180deg, #F8FAFC 0%, #ffffff 100%);
  }
  .stat-row .cell-label { font-size: 13px; color: #64748B; }
  .stat-row .cell-value {
    font-family: "JetBrains Mono", Consolas, monospace;
    font-size: 24px; font-weight: 600; color: #0F172A;
    letter-spacing: -0.5px;
    margin-top: 4px;
  }
  .stat-row .cell.sev-c { border-left-color: #E5484D; }
  .stat-row .cell.sev-h { border-left-color: #F59E0B; }
  .stat-row .cell.sev-m { border-left-color: #F59E0B; }
  .stat-row .cell.sev-l { border-left-color: #0EA5E9; }
  .stat-row .cell.brand { border-left-color: #4F7DF9; }
  .stat-row .cell.good { border-left-color: #16A34A; }
</style>
</head>
<body>

<!-- ============== Cover (page 1) ============== -->
<section class="cover">
  <div class="cover-brand">
    {{if .Assets.LogoURI}}
    <img src="{{.Assets.LogoURI}}" alt="logo"/>
    {{end}}
    <div>
      <div class="cover-brand-name">矩阵云安全平台</div>
      <div class="cover-brand-en">MxCwpp Security Platform</div>
    </div>
  </div>
  <div class="cover-mid">
    <div class="cover-kind">{{.Meta.TaskType}}</div>
    <h1 class="cover-title">任务报告</h1>
    <div class="cover-period">任务 #{{.Meta.TaskIDShort}}</div>
    <div class="cover-deco"></div>

    <div class="cover-highlights">
      <div class="hl"><div class="hl-num">{{.Summary.HostCount}}</div><div class="hl-lbl">覆盖主机</div></div>
      <div class="hl hl-p"><div class="hl-num">{{.Summary.SuccessHosts}}</div><div class="hl-lbl">成功</div></div>
      <div class="hl hl-c"><div class="hl-num">{{.Summary.FailedHosts}}</div><div class="hl-lbl">失败</div></div>
      <div class="hl hl-b"><div class="hl-num">{{printf "%.1f" .Summary.FailureRate}}%</div><div class="hl-lbl">失败率</div></div>
    </div>

    <div class="cover-summary">
      <div class="cover-summary-title">任务概要</div>
      <div class="cover-summary-text">
        本次「<b>{{.Meta.TaskType}}</b>」任务覆盖 <b>{{.Summary.HostCount}}</b> 台主机，
        共执行 <b>{{.Summary.TotalChecks}}</b> 条检查规则；
        通过 <b>{{.Summary.PassedChecks}}</b> 条 / 失败 <b>{{.Summary.FailedChecks}}</b> 条 / 异常 <b>{{.Summary.WarningChecks}}</b> 条，
        合规率 <b>{{printf "%.1f" .Summary.PassRate}}%</b>。
        开始时间 {{.Meta.ExecutedAt}}，结束时间 {{.Meta.CompletedAt}}，总耗时 <b>{{.Meta.Duration}}</b>。
      </div>
    </div>
  </div>
  <div class="cover-meta">
    <div class="cover-meta-row"><span class="cover-meta-label">报告编号</span><span class="cover-meta-value">{{.Meta.ReportID}}</span></div>
    <div class="cover-meta-row"><span class="cover-meta-label">生成时间</span><span class="cover-meta-value">{{.Meta.GeneratedAt}}</span></div>
    <div class="cover-meta-row"><span class="cover-meta-label">任务编号</span><span class="cover-meta-value">{{.Meta.TaskID}}</span></div>
    <div class="cover-meta-row"><span class="cover-meta-label">任务类型</span><span class="cover-meta-value">{{.Meta.TaskType}}</span></div>
    <div class="cover-meta-row"><span class="cover-meta-label">任务名称</span><span class="cover-meta-value">{{.Meta.TaskName}}</span></div>
    <div class="cover-meta-row"><span class="cover-meta-label">关联策略</span><span class="cover-meta-value">{{.Meta.PolicyName}}</span></div>
    <div class="cover-meta-row"><span class="cover-meta-label">计划执行</span><span class="cover-meta-value">{{.Meta.ScheduledAt}}</span></div>
    <div class="cover-meta-row"><span class="cover-meta-label">实际执行</span><span class="cover-meta-value">{{.Meta.ExecutedAt}}</span></div>
    <div class="cover-class">机　密 · 仅 限 内 部 使 用</div>
  </div>
</section>

<!-- ============== TOC (page 2) ============== -->
<section class="page toc force-break">
  <h2>目　录</h2>
  <ol class="toc-list">
    <li><span class="toc-title">执行摘要 · 任务结论概览</span><span class="toc-page">03</span></li>
    <li><span class="toc-title">任务基本信息</span><span class="toc-page">04</span></li>
    <li><span class="toc-title">主机覆盖统计</span><span class="toc-page">05</span></li>
    <li><span class="toc-title">执行结果统计与分布</span><span class="toc-page">06</span></li>
    <li><span class="toc-title">失败原因分布</span><span class="toc-page">07</span></li>
    <li><span class="toc-title">资产清单 · 主机执行明细</span><span class="toc-page">08</span></li>
    <li><span class="toc-title">关键问题汇总（高危 Finding）</span><span class="toc-page">09</span></li>
    <li><span class="toc-title">改进建议与后续行动</span><span class="toc-page">10</span></li>
    <li><span class="toc-title">附录（任务参数、日志摘要）</span><span class="toc-page">11</span></li>
  </ol>
  <div class="toc-extra">
    <div class="toc-block">
      <div class="toc-block-title">数据范围</div>
      <table class="toc-table">
        <tr><td>任务编号</td><td>{{.Meta.TaskID}}</td></tr>
        <tr><td>任务类型</td><td>{{.Meta.TaskType}} · {{.Meta.TaskName}}</td></tr>
        <tr><td>覆盖主机</td><td>{{.Summary.HostCount}} 台 · 规则 {{.Summary.RuleCount}} 条</td></tr>
        <tr><td>执行结果</td><td>通过 {{.Summary.PassedChecks}} / 失败 {{.Summary.FailedChecks}} / 异常 {{.Summary.WarningChecks}} · 合规率 {{printf "%.1f" .Summary.PassRate}}%</td></tr>
        <tr><td>执行时间</td><td>{{.Meta.ExecutedAt}} ~ {{.Meta.CompletedAt}}（{{.Meta.Duration}}）</td></tr>
      </table>
    </div>

    <div class="toc-footer">
      © 矩阵云安全 · MxCwpp Security Platform　|　报告引擎 v1.0　|　所有数据为实时观测，未经任何人工修饰
    </div>
  </div>
</section>

<!-- ============== §1 执行摘要 ============== -->
<section class="page force-break">
  <h2 class="sec">1. 执行摘要</h2>
  <p>
    本报告对任务 <b>{{.Meta.TaskID}}</b>（{{.Meta.TaskType}}）的执行结果进行汇总分析。
    任务于 <b>{{.Meta.ExecutedAt}}</b> 开始执行，<b>{{.Meta.CompletedAt}}</b> 完成，
    总耗时 <b>{{.Meta.Duration}}</b>；覆盖主机 <b>{{.Summary.HostCount}}</b> 台，
    执行检查规则 <b>{{.Summary.RuleCount}}</b> 条，共产生检查记录 <b>{{.Summary.TotalChecks}}</b> 条。
    其中通过 <b>{{.Summary.PassedChecks}}</b> 条（合规率 <b>{{printf "%.1f" .Summary.PassRate}}%</b>）、
    失败 <b>{{.Summary.FailedChecks}}</b> 条、执行异常 <b>{{.Summary.WarningChecks}}</b> 条、
    不适用 <b>{{.Summary.NAChecks}}</b> 条。
    任务最终状态：<b>{{.Meta.StatusLabel}}</b>。
  </p>

  <h3 class="subsec">核心结论</h3>
  <ul>
    {{range .Conclusions}}<li>{{.}}</li>{{end}}
  </ul>

  <h2 class="sec">2. 任务基本信息</h2>
  <table class="t">
    <tbody>
      <tr><td style="width:28%">任务编号</td><td><code>{{.Meta.TaskID}}</code></td></tr>
      <tr><td>任务名称</td><td>{{.Meta.TaskName}}</td></tr>
      <tr><td>任务类型</td><td>{{.Meta.TaskType}}</td></tr>
      <tr><td>任务状态</td><td>{{.Meta.StatusLabel}}</td></tr>
      <tr><td>关联策略</td><td>{{.Meta.PolicyName}}</td></tr>
      <tr><td>目标范围</td><td>{{.Meta.TargetDesc}}</td></tr>
      <tr><td>规则数量</td><td>{{.Summary.RuleCount}} 条</td></tr>
      <tr><td>计划执行时间</td><td>{{.Meta.ScheduledAt}}</td></tr>
      <tr><td>实际开始时间</td><td>{{.Meta.ExecutedAt}}</td></tr>
      <tr><td>实际完成时间</td><td>{{.Meta.CompletedAt}}</td></tr>
      <tr><td>执行耗时</td><td>{{.Meta.Duration}}</td></tr>
      <tr><td>超时配置</td><td>{{.Meta.TimeoutMinutes}} 分钟</td></tr>
      {{if .Meta.FailedReason}}<tr><td>失败原因</td><td style="color:#dc2626">{{.Meta.FailedReason}}</td></tr>{{end}}
    </tbody>
  </table>
</section>

<!-- ============== §3 主机覆盖 ============== -->
<section class="page">
  <h2 class="sec">3. 主机覆盖统计</h2>
  <p>任务下发覆盖目标范围内的主机，按主机维度统计执行状态分布。</p>

  <div class="stat-row">
    <div class="cell brand"><div class="cell-label">下发主机</div><div class="cell-value">{{.Summary.DispatchedHostCount}}</div></div>
    <div class="cell good"><div class="cell-label">完成主机</div><div class="cell-value">{{.Summary.CompletedHostCount}}</div></div>
    <div class="cell sev-h"><div class="cell-label">失败主机</div><div class="cell-value">{{.Summary.FailedHosts}}</div></div>
    <div class="cell sev-m"><div class="cell-label">未响应</div><div class="cell-value">{{.Summary.PendingHosts}}</div></div>
  </div>

  <table class="t">
    <thead><tr><th style="width:30%">维度</th><th class="num" style="width:20%">数量</th><th>说明</th></tr></thead>
    <tbody>
      <tr><td>覆盖主机总数</td><td class="num">{{.Summary.HostCount}}</td><td>任务下发后接收并产生结果的主机数</td></tr>
      <tr><td>已下发主机</td><td class="num">{{.Summary.DispatchedHostCount}}</td><td>任务调度器下发到 Agent 的主机数</td></tr>
      <tr><td>已完成主机</td><td class="num">{{.Summary.CompletedHostCount}}</td><td>已回传结果的主机数</td></tr>
      <tr><td>成功主机</td><td class="num">{{.Summary.SuccessHosts}}</td><td>所有检查均通过或无严重/高危失败</td></tr>
      <tr><td>失败主机</td><td class="num">{{.Summary.FailedHosts}}</td><td>存在严重/高危失败项的主机</td></tr>
      <tr><td>预警主机</td><td class="num">{{.Summary.WarningHosts}}</td><td>存在中低风险失败项的主机</td></tr>
      <tr><td>未响应主机</td><td class="num">{{.Summary.PendingHosts}}</td><td>下发但未回传结果（可能离线或超时）</td></tr>
    </tbody>
  </table>
</section>

<!-- ============== §4 执行结果 ============== -->
<section class="page">
  <h2 class="sec">4. 执行结果统计与分布</h2>
  <p>按检查规则维度汇总本次任务的执行结果，分布如下。</p>

  <div class="stat-row">
    <div class="cell brand"><div class="cell-label">检查总数</div><div class="cell-value">{{.Summary.TotalChecks}}</div></div>
    <div class="cell good"><div class="cell-label">通过</div><div class="cell-value">{{.Summary.PassedChecks}}</div></div>
    <div class="cell sev-c"><div class="cell-label">失败</div><div class="cell-value">{{.Summary.FailedChecks}}</div></div>
    <div class="cell sev-m"><div class="cell-label">异常</div><div class="cell-value">{{.Summary.WarningChecks}}</div></div>
  </div>

  {{if .Charts.StatusPie}}
  <div class="fig">
    {{.Charts.StatusPie}}
    <div class="fig-cap">图 4-1　检查结果状态分布</div>
  </div>
  {{end}}

  <h3 class="subsec">4.1　失败项严重程度分布</h3>
  <table class="t">
    <thead><tr><th>严重程度</th><th class="num" style="width:120px">数量</th><th class="num" style="width:120px">占比</th></tr></thead>
    <tbody>
      {{range .SeverityRows}}
      <tr>
        <td><span class="sev-dot" style="background:{{.Color}}"></span>{{.Label}}</td>
        <td class="num">{{.Count}}</td>
        <td class="num">{{printf "%.1f" .Pct}}%</td>
      </tr>
      {{else}}
      <tr><td class="empty" colspan="3">本次任务无失败项</td></tr>
      {{end}}
    </tbody>
  </table>
</section>

<!-- ============== §5 失败原因分布 ============== -->
<section class="page">
  <h2 class="sec">5. 失败原因分布</h2>
  <p>按类别（Category）维度汇总失败项分布，揭示薄弱配置面。</p>

  {{if .Charts.CategoryPie}}
  <div class="fig">
    {{.Charts.CategoryPie}}
    <div class="fig-cap">图 5-1　失败项类别分布</div>
  </div>
  {{end}}

  {{if .Charts.CategoryBar}}
  <div class="fig">
    {{.Charts.CategoryBar}}
    <div class="fig-cap">图 5-2　Top 类别失败数（柱图）</div>
  </div>
  {{end}}

  <h3 class="subsec">5.1　类别失败统计</h3>
  <table class="t">
    <thead><tr><th style="width:28px">#</th><th>类别</th><th class="num" style="width:90px">失败数</th><th class="num" style="width:90px">占比</th></tr></thead>
    <tbody>
      {{range $i, $r := .CategoryRows}}
      <tr><td>{{add $i 1}}</td><td>{{$r.Label}}</td><td class="num">{{$r.Count}}</td><td class="num">{{printf "%.1f" $r.Pct}}%</td></tr>
      {{else}}
      <tr><td class="empty" colspan="4">本次任务无失败项</td></tr>
      {{end}}
    </tbody>
  </table>
</section>

<!-- ============== §6 资产清单 ============== -->
<section class="page">
  <h2 class="sec">6. 资产清单 · 主机执行明细</h2>
  <p class="no-indent">按主机维度列出本次任务执行结果，含通过/失败/异常项数量与综合得分。</p>

  <table class="t">
    <thead>
      <tr>
        <th style="width:24px">#</th>
        <th>主机名</th>
        <th style="width:110px">IP</th>
        <th style="width:60px">系统</th>
        <th style="width:60px">状态</th>
        <th class="num" style="width:50px">通过</th>
        <th class="num" style="width:50px">失败</th>
        <th class="num" style="width:50px">异常</th>
        <th class="num" style="width:60px">得分</th>
      </tr>
    </thead>
    <tbody>
      {{range $i, $h := .HostRows}}
      <tr>
        <td>{{add $i 1}}</td>
        <td>{{$h.Hostname}}</td>
        <td class="code">{{$h.IP}}</td>
        <td>{{$h.OSFamily}}</td>
        <td><span class="sev-pill" style="background:{{$h.StatusBg}};color:{{$h.StatusColor}}">{{$h.StatusLabel}}</span></td>
        <td class="num">{{$h.PassedCount}}</td>
        <td class="num">{{$h.FailedCount}}</td>
        <td class="num">{{$h.WarningCount}}</td>
        <td class="num">{{printf "%.1f" $h.Score}}</td>
      </tr>
      {{else}}
      <tr><td class="empty" colspan="9">本次任务无主机结果</td></tr>
      {{end}}
    </tbody>
  </table>
</section>

<!-- ============== §7 关键问题汇总 ============== -->
<section class="page">
  <h2 class="sec">7. 关键问题汇总（高危 Finding）</h2>
  <p>按规则维度汇总严重/高危失败项，列出受影响主机以便快速定位整改优先级。</p>

  <table class="t">
    <thead>
      <tr>
        <th style="width:24px">#</th>
        <th>规则名称</th>
        <th style="width:80px">类别</th>
        <th style="width:60px">级别</th>
        <th class="num" style="width:60px">影响主机</th>
      </tr>
    </thead>
    <tbody>
      {{range $i, $r := .CriticalRules}}
      <tr>
        <td>{{add $i 1}}</td>
        <td>{{$r.Title}}</td>
        <td>{{$r.Category}}</td>
        <td><span class="sev-pill" style="background:{{$r.BgColor}};color:{{$r.Color}}">{{$r.Label}}</span></td>
        <td class="num">{{$r.AffectedCount}}</td>
      </tr>
      {{else}}
      <tr><td class="empty" colspan="5">本次任务无严重/高危失败项</td></tr>
      {{end}}
    </tbody>
  </table>

  {{if .CriticalRules}}
  <h3 class="subsec">7.1　修复建议（Top 5）</h3>
  <table class="t">
    <thead>
      <tr>
        <th style="width:24px">#</th>
        <th>规则</th>
        <th>修复建议</th>
      </tr>
    </thead>
    <tbody>
      {{range $i, $r := .CriticalSuggestions}}
      <tr>
        <td>{{add $i 1}}</td>
        <td>{{$r.Title}}</td>
        <td>{{$r.Suggestion}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  {{end}}
</section>

<!-- ============== §8 改进建议 ============== -->
<section class="page">
  <h2 class="sec">8. 改进建议与后续行动</h2>
  <p>基于本次任务执行结果，平台自动生成如下改进建议供安全团队参考：</p>
  <ol>
    {{range .Improvements}}<li>{{.}}</li>{{else}}<li>本次任务执行正常，未生成额外建议。</li>{{end}}
  </ol>

  <h3 class="subsec">8.1　建议复测主机</h3>
  {{if .RetryHosts}}
  <p class="no-indent">以下主机执行存在异常或失败，建议核查连通性后重新下发任务：</p>
  <table class="t">
    <thead><tr><th style="width:24px">#</th><th>主机名</th><th style="width:110px">IP</th><th>原因</th></tr></thead>
    <tbody>
      {{range $i, $h := .RetryHosts}}
      <tr><td>{{add $i 1}}</td><td>{{$h.Hostname}}</td><td class="code">{{$h.IP}}</td><td>{{$h.Reason}}</td></tr>
      {{end}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-block">本次任务所有主机均执行完成，无需复测。</div>
  {{end}}
</section>

<!-- ============== §9 附录 ============== -->
<section class="page">
  <h2 class="sec">9. 附录</h2>

  <h3 class="subsec">附录 A　任务参数</h3>
  <table class="t">
    <tbody>
      <tr><td style="width:30%">任务编号</td><td><code>{{.Meta.TaskID}}</code></td></tr>
      <tr><td>任务类型</td><td>{{.Meta.TaskType}}（{{.Meta.TaskTypeRaw}}）</td></tr>
      <tr><td>目标类型</td><td>{{.Meta.TargetType}}</td></tr>
      <tr><td>目标范围</td><td>{{.Meta.TargetDesc}}</td></tr>
      <tr><td>策略列表</td><td>{{.Meta.PolicyName}}</td></tr>
      <tr><td>超时配置</td><td>{{.Meta.TimeoutMinutes}} 分钟</td></tr>
      <tr><td>下发主机</td><td>{{.Summary.DispatchedHostCount}} 台</td></tr>
      <tr><td>完成主机</td><td>{{.Summary.CompletedHostCount}} 台</td></tr>
    </tbody>
  </table>

  <h3 class="subsec">附录 B　报告说明</h3>
  <table class="t">
    <tbody>
      <tr><td style="width:30%">数据来源</td><td>MySQL（scan_tasks / scan_results / hosts / policies 元数据）</td></tr>
      <tr><td>生成方式</td><td>矩阵云安全平台服务端 Go html/template 渲染，自动生成无人工调整</td></tr>
      <tr><td>图表渲染</td><td>服务端 SVG 手绘，矢量化、可缩放、PDF 中保持清晰</td></tr>
      <tr><td>PDF 引擎</td><td>Chromium Headless（Gotenberg HTML→PDF），文本可搜索、可复制、可粘贴</td></tr>
      <tr><td>报告编号</td><td>{{.Meta.ReportID}}</td></tr>
      <tr><td>生成时间</td><td>{{.Meta.GeneratedAt}}</td></tr>
      <tr><td>密级</td><td>机密 · 仅限内部使用 · 不得转发至非授权人员</td></tr>
    </tbody>
  </table>

  <h3 class="subsec">附录 C　术语对照</h3>
  <table class="t">
    <thead><tr><th style="width:25%">术语</th><th>定义</th></tr></thead>
    <tbody>
      <tr><td>Pass / 通过</td><td>检查项符合基线要求，无需整改</td></tr>
      <tr><td>Fail / 失败</td><td>检查项不符合基线要求，需要整改</td></tr>
      <tr><td>Error / 异常</td><td>检查过程出错（命令执行失败、超时、权限不足等）</td></tr>
      <tr><td>NA / 不适用</td><td>当前主机环境不适用此规则（如服务未安装）</td></tr>
      <tr><td>合规率</td><td>Pass 数 / 总检查数 × 100%</td></tr>
      <tr><td>失败率</td><td>失败主机数 / 覆盖主机数 × 100%</td></tr>
    </tbody>
  </table>
</section>

</body>
</html>
